# Normaliza fim de linha entre Windows/Linux/macOS.
* text=auto

# Scripts shell DEVEM ter LF mesmo no Windows, senão o bash quebra
# (ex.: "set: pipefail / invalid option name"). Não mexer.
*.sh text eol=lf

# Scripts PowerShell ficam com CRLF.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Código e config com LF.
*.cs   text eol=lf
*.csproj text eol=lf
*.sln  text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.md   text eol=lf

# Artefatos de deploy: são consumidos por Docker/Caddy em Linux. CRLF num
# Dockerfile quebra a continuação de linha (`\`), e num .env entra \r no fim do
# valor — a senha do Postgres vira outra senha. LF mesmo quando clonado no Windows.
Dockerfile text eol=lf
.dockerignore text eol=lf
.env.example text eol=lf
deploy/Caddyfile text eol=lf

# Binários (não normalizar).
*.png binary
*.jpg binary
*.exe binary
*.dll binary
