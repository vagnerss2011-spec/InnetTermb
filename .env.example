# RemoteOps Cloud — modelo de configuração do deploy.
#
#   cp .env.example .env    e preencha os valores VAZIOS abaixo.
#
# O .env real NUNCA é commitado (está no .gitignore) e NÃO tem valor de exemplo
# aqui de propósito: segredo em arquivo de template vira segredo de produção no
# dia em que alguém tem pressa. Cada campo diz o comando que gera o valor.
# Passo a passo completo: docs/runbook-deploy-debian.md

# ── Banco ────────────────────────────────────────────────────────────────────
# Gere com:  openssl rand -base64 24
# Trocar depois exige recriar o volume pgdata (a senha fica gravada no initdb).
POSTGRES_PASSWORD=

# Opcionais (têm default no compose):
# POSTGRES_DB=remoteops
# POSTGRES_USER=remoteops

# ── Chave de assinatura do JWT ───────────────────────────────────────────────
# Gere com:  openssl rand -base64 32
# Mínimo 32 bytes (256 bits) depois de decodificar — a API recusa subir se for
# menor. Trocar esta chave invalida todos os access tokens em circulação (os
# clientes renovam sozinhos pelo refresh token).
JWT_SECRET_KEY_BASE64=

# ── HTTPS ────────────────────────────────────────────────────────────────────
# Hostname público, já apontado no DNS para o IP deste servidor. É o que vai em
# REMOTEOPS_CLOUD_URL no app (https://<hostname>).
REMOTEOPS_PUBLIC_HOSTNAME=

# E-mail para o Let's Encrypt avisar de expiração/problema no certificado.
ACME_EMAIL=

# ── Opcional ─────────────────────────────────────────────────────────────────
# Chave dedicada do decoy anti-enumeração do /auth/kdf (openssl rand -base64 32).
# Vazio = derivada da chave do JWT via HKDF; funciona, mas trocar a chave do JWT
# passa a mudar os salts decoy.
# AUTH_KDF_DECOY_KEY_BASE64=

# Identidade do token. Mude só se souber o porquê: precisa bater com o cliente.
# JWT_ISSUER=remoteops-cloud
# JWT_AUDIENCE=remoteops-desktop
