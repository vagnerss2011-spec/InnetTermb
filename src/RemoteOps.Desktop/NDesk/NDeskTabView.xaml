<UserControl x:Class="RemoteOps.Desktop.NDesk.NDeskTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#1e1e1e">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Painel do operador -->
        <Grid Grid.Column="0" DataContext="{Binding Operator}" Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Operador" Foreground="White" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBox Width="140" Text="{Binding TicketIdInput, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Ticket (gere um novo ou cole um existente)"/>
                <Button Content="Gerar ticket" Command="{Binding GenerateTicketCommand}" Margin="6,0,0,0"/>
                <Button Content="Conectar" Command="{Binding ConnectCommand}" Margin="6,0,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Estado: " Foreground="#aaa" FontSize="11"/>
                <TextBlock Text="{Binding State}" Foreground="#ccc" FontSize="11" FontWeight="SemiBold" Margin="0,0,12,0"/>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#e06c75" FontSize="11" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Superfície de vídeo placeholder -->
            <Border Grid.Row="3" Background="#111" BorderBrush="#333" BorderThickness="1" Margin="0,0,0,8">
                <TextBlock Text="Tela remota (placeholder)" Foreground="#666" FontStyle="Italic"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Opacity" Value="0.3"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding State}" Value="Connected">
                                <Setter Property="Opacity" Value="1"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>

            <!-- Banner + Encerrar sempre acessível durante a sessão -->
            <Border Grid.Row="4" Background="#5a1d1d" Padding="8,6">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSessionActive}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Sessão NDesk em andamento — visível para o usuário atendido"
                               Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Encerrar" Command="{Binding EndCommand}"/>
                </Grid>
            </Border>
        </Grid>

        <Rectangle Grid.Column="1" Fill="#333"/>

        <!-- Painel mock do lado atendido -->
        <Grid Grid.Column="2" DataContext="{Binding Assisted}" Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Lado atendido (mock)" Foreground="White" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>

            <StackPanel Grid.Row="1">
                <TextBlock Text="Nenhuma solicitação pendente." Foreground="#888" FontStyle="Italic">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasPendingRequest}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasPendingRequest}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- Mode=OneWay explícito: Run.Text tem BindsTwoWayByDefault=true no WPF.
                         Sem isso, qualquer uma destas propriedades vindo a ser somente-leitura
                         (como PermissionsRequestedText) derruba o app inteiro ao anexar o
                         binding — InvalidOperationException não capturada em App.OnStartup. -->
                    <TextBlock Foreground="#ccc" FontSize="11" Margin="0,0,0,4">
                        <Run Text="Operador: "/>
                        <Run Text="{Binding PendingConsent.OperatorDisplayName, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                    <TextBlock Foreground="#ccc" FontSize="11" Margin="0,0,0,4">
                        <Run Text="Empresa: "/>
                        <Run Text="{Binding PendingConsent.CompanyName, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                    <TextBlock Foreground="#ccc" FontSize="11" Margin="0,0,0,4">
                        <Run Text="Ticket: "/>
                        <Run Text="{Binding PendingConsent.TicketId, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                    <TextBlock Foreground="#ccc" FontSize="11" Margin="0,0,0,4">
                        <Run Text="Modo solicitado: "/>
                        <Run Text="{Binding PendingConsent.RequestedMode, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                    <TextBlock Foreground="#ccc" FontSize="11" Margin="0,0,0,8">
                        <Run Text="Permissões: "/>
                        <Run Text="{Binding PermissionsRequestedText, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Aceitar" Command="{Binding AcceptCommand}" Margin="0,0,6,0"/>
                        <Button Content="Recusar" Command="{Binding DeclineCommand}"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock Text="{Binding State}" Foreground="#aaa" FontSize="11" Margin="0,8,0,8"/>
                <Button Content="Encerrar" Command="{Binding EndCommand}" HorizontalAlignment="Left"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
