<Window x:Class="RemoteOps.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:RemoteOps.Desktop"
        xmlns:views="clr-namespace:RemoteOps.Desktop.Views"
        xmlns:vm="clr-namespace:RemoteOps.Desktop.ViewModels"
        xmlns:terminal="clr-namespace:RemoteOps.Desktop.Terminal"
        xmlns:rdp="clr-namespace:RemoteOps.Desktop.Rdp"
        xmlns:ndesk="clr-namespace:RemoteOps.Desktop.NDesk"
        Title="RemoteOps" Height="720" Width="1280"
        MinHeight="480" MinWidth="800"
        Background="{DynamicResource Brush.Bg.App}"
        Foreground="{DynamicResource Brush.Text.Primary}"
        FontFamily="{DynamicResource Font.Family.Base}"
        FontSize="{DynamicResource Font.Size.Body}">

    <Window.InputBindings>
        <KeyBinding Modifiers="Ctrl" Key="W" Command="{Binding Tabs.CloseActiveTabCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <!-- Cabeçalho + conteúdo da aba fixa "Hosts": o item marcador na CompositeCollection
             abaixo é o próprio WorkspaceViewModel (DataContext da janela). -->
        <DataTemplate DataType="{x:Type vm:WorkspaceViewModel}" x:Key="HostsHeaderTemplate">
            <TextBlock Text="Hosts"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WorkspaceViewModel}">
            <views:BrowserView DataContext="{Binding Browser}"/>
        </DataTemplate>

        <!-- Cabeçalho das abas de sessão: protocolo + título + botão fechar -->
        <DataTemplate DataType="{x:Type vm:SessionTabViewModel}" x:Key="SessionHeaderTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding ProtocolLabel}"
                           FontSize="9"
                           Foreground="{DynamicResource Brush.Text.Tertiary}"
                           Margin="0,0,4,0"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                <Button Content="✕"
                        Command="{Binding DataContext.Tabs.CloseTabCommand,
                                  RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}"
                        Margin="6,0,0,0"
                        Padding="2,0"
                        VerticalAlignment="Center"
                        BorderThickness="0"
                        Background="Transparent"
                        FontSize="9"/>
            </StackPanel>
        </DataTemplate>

        <!-- Conteúdo das abas de sessão (por tipo de ViewModel) — mesmo conjunto do TabsView -->
        <DataTemplate DataType="{x:Type terminal:TerminalTabViewModel}">
            <terminal:TerminalTabView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type rdp:RdpTabViewModel}">
            <rdp:RdpTabView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type ndesk:NDeskTabViewModel}">
            <ndesk:NDeskTabView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SessionTabViewModel}">
            <TextBlock Text="{Binding Title}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource Brush.Text.Tertiary}"
                       FontSize="13"
                       FontStyle="Italic"/>
        </DataTemplate>

        <!-- Escolhe o DataTemplate de cabeçalho pelo tipo do item: WorkspaceViewModel (aba
             fixa Hosts, com x:Key acima) ou SessionTabViewModel/derivados (abas de sessão). -->
        <local:MainTabHeaderTemplateSelector x:Key="TabHeaderSelector"
                                              HostsTemplate="{StaticResource HostsHeaderTemplate}"
                                              SessionTemplate="{StaticResource SessionHeaderTemplate}"/>
    </Window.Resources>

    <!-- TabControl raiz: ItemsSource é montado em MainWindow.xaml.cs (item 0 = o próprio
         WorkspaceViewModel, aba fixa "Hosts" sem botão fechar; itens seguintes espelham
         Tabs.Tabs, uma aba por sessão aberta). Um Binding declarativo dentro de
         CompositeCollection não é aceito pelo WPF ("Binding só pode ser definido em uma
         DependencyProperty"), daí o merge ser feito em código. O ContentTemplate resolve
         implicitamente pelos DataTemplate sem x:Key acima (por DataType). -->
    <local:TabControlEx x:Name="TabsHost"
                        Background="{DynamicResource Brush.Bg.Canvas}"
                        BorderBrush="{DynamicResource Brush.Border.Subtle}"
                        ItemTemplateSelector="{StaticResource TabHeaderSelector}">
        <!-- Template keep-alive: em vez do ContentPresenter único (SelectedContent) que recria o
             conteúdo a cada troca de aba, o TabControlEx mantém um ContentPresenter por aba vivo
             dentro de PART_ItemsHolder e só alterna Visibility — o terminal (WebView2/xterm + sessão
             SSH) não é destruído ao ir pra "Hosts" e voltar. Estrutura da moldura idêntica ao tema
             (Themes/Controls/TabControl.xaml); só troca o host de conteúdo. -->
        <local:TabControlEx.Template>
            <ControlTemplate TargetType="{x:Type local:TabControlEx}">
                <Grid KeyboardNavigation.TabNavigation="Local" SnapsToDevicePixels="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TabPanel x:Name="HeaderPanel"
                              Grid.Row="0"
                              IsItemsHost="True"
                              KeyboardNavigation.TabIndex="1"
                              Panel.ZIndex="1"/>
                    <Border Grid.Row="1"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="0,1,0,0">
                        <Grid x:Name="PART_ItemsHolder"/>
                    </Border>
                </Grid>
            </ControlTemplate>
        </local:TabControlEx.Template>
    </local:TabControlEx>
</Window>
