<UserControl
    x:Class="RemoteOps.Desktop.Views.TerminalTabView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">

    <Grid>
        <!-- Loading overlay -->
        <TextBlock
            Text="Conectando…"
            Visibility="{Binding IsConnecting, Converter={StaticResource BoolToVisibilityConverter}}"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            Foreground="#999" FontSize="14"/>

        <!-- Error overlay -->
        <TextBlock
            Text="{Binding ErrorMessage}"
            Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            Foreground="#e06c75" FontSize="13" TextWrapping="Wrap"
            Margin="24"/>

        <!-- Terminal WebView2 -->
        <wv2:WebView2
            x:Name="WebView"
            Visibility="{Binding IsConnecting, Converter={StaticResource BoolToHiddenConverter}}"/>
    </Grid>
</UserControl>
