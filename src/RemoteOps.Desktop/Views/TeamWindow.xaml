<Window x:Class="RemoteOps.Desktop.Views.TeamWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RemoteOps — Equipe" Height="600" Width="660" MinHeight="420" MinWidth="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Bg.App}"
        Foreground="{DynamicResource Brush.Text.Primary}"
        FontFamily="{DynamicResource Font.Family.Base}"
        FontSize="{DynamicResource Font.Size.Body}">
    <!--
        Tela de Equipe (Fatia 1e). Como nas demais janelas, os controles NÃO levam
        Background/Foreground/BorderBrush locais: o tema define estilo IMPLÍCITO por TargetType, e
        estilo local é o que produz o controle "claro do Aero2" no meio da janela escura.

        A ordem dos blocos é a ordem em que o operador precisa das informações:
        1) em qual cofre ele está (o erro caro desta fatia acontece por não saber);
        2) quem está no time;
        3) o que a remoção faz — e o que ela NÃO faz.
    -->
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <DockPanel Margin="20">

        <!-- ── Rodapé de ações ─────────────────────────────────────────────── -->
        <!--
            ⚠️ O botão de CONVIDAR só existe numa sessão de cofre de TIME. Numa sessão pessoal o
            convite apontaria para o cofre com todos os clientes do operador — e ele não some calado:
            o painel logo abaixo diz o motivo e o próximo passo.
        -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,14,0,0">
            <Button x:Name="InviteButton" Content="Convidar alguém…"
                    Command="{Binding InviteCommand}"
                    Style="{DynamicResource Button.Primary}" Padding="10,5" Margin="0,0,8,0"
                    Visibility="{Binding CanInvite, Converter={StaticResource BoolToVis}}"/>
            <Button x:Name="ReloadButton" Content="Atualizar"
                    Command="{Binding ReloadCommand}" Padding="10,5"/>
        </StackPanel>

        <Border x:Name="InviteBlockedPanel" DockPanel.Dock="Bottom" Margin="0,14,0,0" Padding="10,7"
                CornerRadius="{DynamicResource Radius.Control}"
                Background="{DynamicResource Brush.Bg.Canvas}"
                BorderBrush="{DynamicResource Brush.Border.Subtle}"
                BorderThickness="1"
                Visibility="{Binding HasInviteBlockedNotice, Converter={StaticResource BoolToVis}}">
            <TextBlock x:Name="InviteBlockedText" Text="{Binding InviteBlockedNotice}"
                       Style="{DynamicResource Text.Caption}" TextWrapping="Wrap"/>
        </Border>

        <!-- ── Cabeçalho ───────────────────────────────────────────────────── -->
        <StackPanel DockPanel.Dock="Top">
            <TextBlock Text="{Binding Title}" Style="{DynamicResource Text.TitleLg}" Margin="0,0,0,10"/>

            <!-- Indicador de cofre. Fica AQUI, e não só na barra do shell, porque é nesta tela que o
                 operador está pensando "o que é do time e o que é meu" — e nesta versão a resposta
                 ainda é "tudo é seu". Borda de alerta quando o workspace é de time. -->
            <Border Margin="0,0,0,14" Padding="12"
                    CornerRadius="{DynamicResource Radius.Surface}"
                    Background="{DynamicResource Brush.Bg.Canvas}"
                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Vault.IsWarning}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Brush.Status.CriticalSurface}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Status.CriticalBase}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock x:Name="VaultBadgeWarningIcon"
                                   Text="{DynamicResource Icon.Warning}"
                                   FontFamily="{DynamicResource Font.Family.Icons}"
                                   Foreground="{DynamicResource Brush.Status.Error}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"
                                   Visibility="{Binding Vault.IsWarning, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock x:Name="VaultBadgeText" Text="{Binding Vault.Label}"
                                   Style="{DynamicResource Text.BodyStrong}"
                                   TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="VaultBadgeDetail" Text="{Binding Vault.Detail}"
                               Style="{DynamicResource Text.Caption}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Carregando: dito com todas as letras. Sem isto, a janela mostraria a moldura vazia e
                 o operador leria "o time não tem ninguém". -->
            <TextBlock x:Name="LoadingText" Text="Carregando os membros do time…"
                       Style="{DynamicResource Text.Caption}" Margin="0,0,0,10"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

            <!-- Lista que NÃO carregou. A lista some junto (ShowMembers fica falso): uma lista vazia
                 desenhada aqui diria ao operador que ele perdeu o time. -->
            <Border x:Name="LoadErrorPanel" Margin="0,0,0,10" Padding="12"
                    CornerRadius="{DynamicResource Radius.Control}"
                    Background="{DynamicResource Brush.Status.CriticalSurface}"
                    BorderBrush="{DynamicResource Brush.Status.CriticalBase}"
                    BorderThickness="1"
                    Visibility="{Binding HasLoadError, Converter={StaticResource BoolToVis}}">
                <TextBlock x:Name="LoadErrorText" Text="{Binding LoadError}" TextWrapping="Wrap"
                           Foreground="{DynamicResource Brush.Text.Primary}"/>
            </Border>

            <!-- Resposta sem ninguém: anormal, e a tela diz isso. -->
            <Border x:Name="EmptyPanel" Margin="0,0,0,10" Padding="12"
                    CornerRadius="{DynamicResource Radius.Control}"
                    Background="{DynamicResource Brush.Bg.Canvas}"
                    BorderBrush="{DynamicResource Brush.Border.Subtle}"
                    BorderThickness="1"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                <TextBlock x:Name="EmptyText" Text="{Binding EmptyMessage}" TextWrapping="Wrap"
                           Style="{DynamicResource Text.Caption}"/>
            </Border>
        </StackPanel>

        <!-- ── Confirmação da remoção ──────────────────────────────────────── -->
        <!--
            Fica no rodapé, ACIMA dos botões, e é um painel inteiro — não um tooltip, não um
            MessageBox curto. A frase da RemovalTruth é o coração desta tela: remover corta o acesso
            FUTURO e não apaga o que a pessoa já viu. Esconder isso seria prometer menos do que a
            criptografia entrega, num assunto de segurança.
        -->
        <Border x:Name="RemovalConfirmPanel" DockPanel.Dock="Bottom" Margin="0,14,0,0" Padding="12"
                CornerRadius="{DynamicResource Radius.Surface}"
                Background="{DynamicResource Brush.Status.CriticalSurface}"
                BorderBrush="{DynamicResource Brush.Status.CriticalBase}"
                BorderThickness="1"
                Visibility="{Binding IsRemovalConfirmVisible, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock x:Name="RemovalQuestionText" Text="{Binding RemovalQuestion}"
                           Style="{DynamicResource Text.BodyStrong}" TextWrapping="Wrap"
                           Margin="0,0,0,6"/>
                <TextBlock x:Name="RemovalWarningText" Text="{Binding RemovalWarning}"
                           TextWrapping="Wrap" Margin="0,0,0,10"
                           Foreground="{DynamicResource Brush.Text.Primary}"/>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="ConfirmRemoveButton" Content="Sim, remover do time"
                            Command="{Binding ConfirmRemoveCommand}"
                            Style="{DynamicResource Button.Danger}"
                            IsEnabled="{Binding IsIdle}" Padding="10,5" Margin="0,0,8,0"/>
                    <Button x:Name="CancelRemoveButton" Content="Cancelar"
                            Command="{Binding CancelRemoveCommand}" Padding="10,5"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Retorno das ações (erro e sucesso) ──────────────────────────── -->
        <StackPanel DockPanel.Dock="Bottom">
            <Border x:Name="ActionErrorPanel" Margin="0,12,0,0" Padding="10,7"
                    CornerRadius="{DynamicResource Radius.Control}"
                    Background="{DynamicResource Brush.Status.CriticalSurface}"
                    BorderBrush="{DynamicResource Brush.Status.CriticalBase}"
                    BorderThickness="1"
                    Visibility="{Binding HasActionError, Converter={StaticResource BoolToVis}}">
                <TextBlock x:Name="ActionErrorText" Text="{Binding ActionError}" TextWrapping="Wrap"
                           Foreground="{DynamicResource Brush.Text.Primary}"/>
            </Border>

            <TextBlock x:Name="StatusText" Text="{Binding StatusMessage}" TextWrapping="Wrap"
                       Style="{DynamicResource Text.Caption}" Margin="0,12,0,0"
                       Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>

        <!-- ── A lista ─────────────────────────────────────────────────────── -->
        <ListBox x:Name="MembersList" ItemsSource="{Binding Members}"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 Visibility="{Binding ShowMembers, Converter={StaticResource BoolToVis}}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4,7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding DisplayName}"
                                       Style="{DynamicResource Text.BodyStrong}" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding Email}"
                                       Style="{DynamicResource Text.Caption}" TextWrapping="Wrap"/>
                            <!-- Quem ainda não tem a chave aparece ESCRITO na linha, não num tooltip:
                                 esse membro enxerga a lista e não abre senha nenhuma. -->
                            <TextBlock Text="{Binding KeyWarning}"
                                       Style="{DynamicResource Text.Caption}" TextWrapping="Wrap"
                                       Foreground="{DynamicResource Brush.Status.Pending}"
                                       Visibility="{Binding HasKeyWarning, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>

                        <Border Grid.Column="1" VerticalAlignment="Center" Margin="10,0,10,0"
                                Padding="8,2" CornerRadius="8"
                                Background="{DynamicResource Brush.Accent.Muted}">
                            <TextBlock Text="{Binding RoleLabel}"
                                       Style="{DynamicResource Text.Caption}"
                                       Foreground="{DynamicResource Brush.Accent.Base}"/>
                        </Border>

                        <!-- O comando mora na VM da JANELA, não na do item: o RelativeSource sobe até
                             a Window. Um binding direto resolveria contra o TeamMemberViewModel,
                             não acharia nada e falharia EM SILÊNCIO (o WPF não lança em binding
                             quebrado) — o botão ficaria desenhado e inerte. -->
                        <Button Grid.Column="2" Content="Remover…" VerticalAlignment="Center"
                                Padding="10,4"
                                Command="{Binding DataContext.RemoveCommand,
                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
