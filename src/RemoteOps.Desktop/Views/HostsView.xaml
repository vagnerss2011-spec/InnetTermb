<UserControl x:Class="RemoteOps.Desktop.Views.HostsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RemoteOps.Desktop.ViewModels"
             xmlns:views="clr-namespace:RemoteOps.Desktop.Views">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <DockPanel Background="{DynamicResource Brush.Bg.Surface}">

        <!-- Barra de ferramentas: busca + novo host/grupo -->
        <Grid DockPanel.Dock="Top" Margin="{DynamicResource Thickness.PanelPadding}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Buscar por nome, endereço ou tag"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0"/>

            <Button Grid.Column="1"
                    Content="Novo host"
                    Style="{DynamicResource Button.Primary}"
                    Command="{Binding NewHostCommand}"
                    Margin="0,0,4,0"/>

            <Button Grid.Column="2"
                    Content="{DynamicResource Icon.ChevronDown}"
                    FontFamily="{DynamicResource Font.Family.Icons}"
                    ToolTip="Mais opções"
                    Padding="6,4"
                    Click="NewMenuButton_Click">
                <Button.ContextMenu>
                    <ContextMenu x:Name="NewMenu" Placement="Bottom">
                        <MenuItem Header="Novo grupo" Command="{Binding NewGroupCommand}"/>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
        </Grid>

        <!-- Breadcrumb -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource Brush.Bg.SurfaceRaised}"
                BorderBrush="{DynamicResource Brush.Border.Subtle}"
                BorderThickness="0,1,0,1"
                Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <Button Style="{DynamicResource Button.Ghost}"
                        Command="{Binding BackCommand}"
                        Margin="0,0,8,0"
                        Visibility="{Binding IsInGroup, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource Icon.Back}"
                                   FontFamily="{DynamicResource Font.Family.Icons}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Voltar"
                                   Margin="4,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="{Binding BreadcrumbLabel}"
                           Style="{DynamicResource Text.Secondary}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Conteúdo: grid de grupos (fora de um grupo) ou grid de hosts (dentro de um grupo) -->
        <Grid>

            <!-- Estado vazio: sem grupos -->
            <TextBlock Text="Nenhum grupo ainda. Clique na seta ao lado de &quot;Novo host&quot; para criar o primeiro grupo."
                       TextWrapping="Wrap"
                       Margin="24"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource Text.Secondary}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsInGroup}" Value="False"/>
                                    <Condition Binding="{Binding Groups.Count}" Value="0"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Grid de grupos (cards) -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsInGroup}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>

                <ItemsControl ItemsSource="{Binding Groups}" Margin="16">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:GroupCardViewModel}">
                            <Border Background="{DynamicResource Brush.Bg.SurfaceRaised}"
                                    BorderBrush="{DynamicResource Brush.Border.Default}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource Radius.Surface}"
                                    Width="160" Height="90"
                                    Margin="0,0,12,12"
                                    Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.OpenGroupCommand,
                                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <StackPanel Margin="12" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               Style="{DynamicResource Text.BodyStrong}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding HostCountLabel}"
                                               Style="{DynamicResource Text.Caption}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Estado vazio: grupo sem hosts -->
            <TextBlock Text="Nenhum host neste grupo. Clique em &quot;Novo host&quot; para adicionar o primeiro."
                       TextWrapping="Wrap"
                       Margin="24"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource Text.Secondary}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsInGroup}" Value="True"/>
                                    <Condition Binding="{Binding Hosts.Count}" Value="0"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Área de hosts: chips de filtro por tipo/vendor (topo) + grid -->
            <DockPanel Visibility="{Binding IsInGroup, Converter={StaticResource BoolToVis}}">
                <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding DeviceFilters}" Margin="0,0,0,6">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.ApplyFilterCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}" Cursor="Hand" Margin="0,0,6,6">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Chip" Background="{DynamicResource Brush.Bg.SurfaceRaised}"
                                                BorderBrush="{DynamicResource Brush.Border.Default}" BorderThickness="1"
                                                CornerRadius="10" Padding="11,3" SnapsToDevicePixels="True">
                                            <TextBlock x:Name="ChipText" Text="{Binding Label}"
                                                       Foreground="{DynamicResource Brush.Text.Primary}" FontSize="12"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter TargetName="Chip" Property="Background" Value="{DynamicResource Brush.Accent.Base}"/>
                                                <Setter TargetName="Chip" Property="BorderBrush" Value="{DynamicResource Brush.Accent.Base}"/>
                                                <Setter TargetName="ChipText" Property="Foreground" Value="{DynamicResource Brush.Text.OnAccent}"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Chip" Property="BorderBrush" Value="{DynamicResource Brush.Accent.Base}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <DataGrid x:Name="HostsGrid"
                          ItemsSource="{Binding Hosts}"
                          SelectedItem="{Binding SelectedHost, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          SelectionMode="Single"
                          BorderThickness="0"
                          CanUserResizeRows="False">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <EventSetter Event="MouseDoubleClick" Handler="HostRow_MouseDoubleClick"/>
                        <EventSetter Event="PreviewMouseRightButtonDown" Handler="Row_PreviewMouseRightButtonDown"/>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Conectar via SSH"    Command="{Binding ConnectCommand}" CommandParameter="ssh"/>
                        <MenuItem Header="Conectar via Telnet" Command="{Binding ConnectCommand}" CommandParameter="telnet"/>
                        <MenuItem Header="Conectar via RDP"    Command="{Binding ConnectCommand}" CommandParameter="rdp"/>
                        <MenuItem Header="Abrir WinBox"        Command="{Binding ConnectCommand}" CommandParameter="mikrotik"/>
                        <Separator/>
                        <MenuItem Header="Editar"              Command="{Binding EditHostCommand}"/>
                        <MenuItem Header="Excluir"             Command="{Binding DeleteHostCommand}"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Nome" Width="*" SortMemberPath="Name">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <views:DeviceIcon Role="{Binding DeviceRole}" VendorKey="{Binding VendorKey}"
                                                      VerticalAlignment="Center" Margin="0,0,7,0"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Protocolo" Binding="{Binding PrimaryProtocol}" Width="90"/>
                    <DataGridTextColumn Header="Endereço"  Binding="{Binding PrimaryAddress}"  Width="*"/>
                    <DataGridTemplateColumn Header="Tipo" Width="150" SortMemberPath="RoleLabel">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <views:DeviceIcon Role="{Binding DeviceRole}"
                                                      VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding RoleLabel}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Vendor"    Binding="{Binding Vendor}"           Width="110"/>
                    <DataGridTextColumn Header="Tags"      Binding="{Binding Tags}"             Width="140"/>
                </DataGrid.Columns>
            </DataGrid>
            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>
