<Window x:Class="RemoteOps.Desktop.Views.PasswordRecoveryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RemoteOps — Recuperar senha" Height="Auto" Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource Brush.Bg.App}"
        Foreground="{DynamicResource Brush.Text.Primary}"
        FontFamily="{DynamicResource Font.Family.Base}"
        FontSize="{DynamicResource Font.Size.Body}">
    <!--
        Esqueci a senha (Fase 4 E2EE). Dois passos. Como na AccountWindow, os controles NÃO levam
        Background/Foreground/BorderBrush aqui: o tema define estilo IMPLÍCITO por TargetType — estilo
        local é o que produz o controle "claro do Aero2" no meio da janela escura.
    -->
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <StackPanel Margin="20">
        <TextBlock Text="Recuperar senha" Style="{DynamicResource Text.TitleLg}" Margin="0,0,0,4"/>

        <!-- ── Passo 1: pedir o código por e-mail ── -->
        <StackPanel Visibility="{Binding IsRequestStep, Converter={StaticResource BoolToVis}}">
            <TextBlock Style="{DynamicResource Text.Caption}" TextWrapping="Wrap" Margin="0,0,0,12"
                       Text="Informe o e-mail da conta. Se houver uma conta com esse e-mail, enviaremos um código de recuperação. Você também vai precisar da sua chave de recuperação."/>

            <TextBlock Text="E-mail" Style="{DynamicResource Text.Caption}" Margin="0,0,0,2"/>
            <TextBox x:Name="EmailField" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding IsIdle}" Margin="0,0,0,10"/>

            <Button x:Name="RequestButton" Content="Enviar código" Style="{DynamicResource Button.Primary}"
                    IsDefault="True" IsEnabled="{Binding IsIdle}" Click="Request_Click"
                    Padding="10,6" Margin="0,4,0,10"/>
        </StackPanel>

        <!-- ── Passo 2: código + chave de recuperação + nova senha ── -->
        <StackPanel Visibility="{Binding IsCodeStep, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Código de recuperação (do e-mail)" Style="{DynamicResource Text.Caption}" Margin="0,0,0,2"/>
            <TextBox x:Name="TokenField" Text="{Binding Token, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding IsIdle}" Margin="0,0,0,10"/>

            <TextBlock Text="Chave de recuperação" Style="{DynamicResource Text.Caption}" Margin="0,0,0,2"/>
            <TextBox x:Name="RecoveryKeyField" Text="{Binding RecoveryKey, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding IsIdle}" Margin="0,0,0,4"/>

            <Border Background="{DynamicResource Brush.Status.CriticalSurface}"
                    BorderBrush="{DynamicResource Brush.Status.CriticalBase}"
                    BorderThickness="1" CornerRadius="{DynamicResource Radius.Control}"
                    Padding="10,6" Margin="0,0,0,10">
                <TextBlock TextWrapping="Wrap" Style="{DynamicResource Text.Caption}"
                           Text="A chave de recuperação é a que o RemoteOps mostrou uma vez, ao criar a conta. Só o código do e-mail NÃO reabre o cofre: sem a chave de recuperação, por segurança (E2EE), os dados cifrados não podem ser recuperados."/>
            </Border>

            <TextBlock Text="Nova senha" Style="{DynamicResource Text.Caption}" Margin="0,0,0,2"/>
            <PasswordBox x:Name="NewPasswordField" Height="28" IsEnabled="{Binding IsIdle}" Margin="0,0,0,10"/>

            <TextBlock Text="Confirmar nova senha" Style="{DynamicResource Text.Caption}" Margin="0,0,0,2"/>
            <PasswordBox x:Name="ConfirmPasswordField" Height="28" IsEnabled="{Binding IsIdle}" Margin="0,0,0,10"/>

            <Button x:Name="ResetButton" Content="Redefinir senha" Style="{DynamicResource Button.Primary}"
                    IsDefault="True" IsEnabled="{Binding IsIdle}" Click="Reset_Click"
                    Padding="10,6" Margin="0,4,0,10"/>
        </StackPanel>

        <!-- ── Status + erro (compartilhados pelos dois passos) ── -->
        <TextBlock Text="{Binding StatusMessage}" Style="{DynamicResource Text.Caption}"
                   TextWrapping="Wrap" Margin="0,0,0,8"
                   Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}"/>

        <Border Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                Background="{DynamicResource Brush.Status.CriticalSurface}"
                BorderBrush="{DynamicResource Brush.Status.CriticalBase}"
                BorderThickness="1" CornerRadius="{DynamicResource Radius.Control}"
                Padding="10,6" Margin="0,0,0,10">
            <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap"
                       Foreground="{DynamicResource Brush.Status.Error}"/>
        </Border>

        <Button Content="Voltar ao login" Style="{DynamicResource Button.Ghost}"
                Command="{Binding BackToLoginCommand}" IsEnabled="{Binding IsIdle}"
                HorizontalAlignment="Center" Padding="8,4"/>
    </StackPanel>
</Window>
