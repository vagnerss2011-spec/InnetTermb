<Window x:Class="RemoteOps.Desktop.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurações" Height="560" Width="640"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource Brush.Bg.App}"
        Foreground="{DynamicResource Brush.Text.Primary}"
        FontFamily="{DynamicResource Font.Family.Base}"
        FontSize="{DynamicResource Font.Size.Body}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <DockPanel Margin="16">
        <StackPanel x:Name="GlobalSaveBar" DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock Text="{Binding UpdateStatus}" VerticalAlignment="Center"
                       Foreground="{DynamicResource Brush.Text.Secondary}" Margin="0,0,12,0"/>
            <Button Content="Salvar" Command="{Binding SaveCommand}" MinWidth="88" Padding="10,4"/>
        </StackPanel>
        <TabControl x:Name="Tabs" SelectionChanged="Tabs_SelectionChanged">
            <TabItem Header="Aparência">
                <StackPanel Margin="12">
                    <TextBlock Text="Tema" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding ThemeName}" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Recursos">
                <StackPanel Margin="12">
                    <CheckBox Content="Habilitar RDP (rdp.enabled)" IsChecked="{Binding RdpEnabled}" Margin="0,0,0,8"/>
                    <CheckBox Content="Habilitar assistência NDesk (ndesk.enabled)" IsChecked="{Binding NdeskEnabled}"/>
                    <TextBlock Text="Alterações em recursos podem exigir reiniciar o app."
                               Foreground="{DynamicResource Brush.Text.Tertiary}"
                               FontSize="11" Margin="0,12,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Conta">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12">
                <StackPanel>
                    <TextBlock Text="Sincronização na nuvem" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="Tenha sua conta e as senhas dos equipamentos em qualquer PC, cifradas de ponta a ponta. Opcional: desligada, o RemoteOps é 100% local."
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>

                    <CheckBox Content="Ativar sincronização na nuvem" IsChecked="{Binding CloudSyncEnabled}" Margin="0,0,0,8"/>

                    <TextBlock Text="Endereço do servidor (https://…)" FontSize="11"
                               Foreground="{DynamicResource Brush.Text.Tertiary}" Margin="0,0,0,2"/>
                    <TextBox Text="{Binding CloudServerUrl, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding CloudSyncEnabled}" Margin="0,0,0,8"/>

                    <TextBlock Text="{Binding CloudConfigError}" TextWrapping="Wrap" Margin="0,0,0,8"
                               Foreground="{DynamicResource Brush.Status.Error}"
                               Visibility="{Binding HasCloudConfigError, Converter={StaticResource BoolToVis}}"/>

                    <Button Content="Aplicar e reiniciar" Command="{Binding SaveAndRestartCommand}"
                            Style="{DynamicResource Button.Primary}" HorizontalAlignment="Left" Padding="10,4"/>
                    <TextBlock Text="O RemoteOps reinicia para aplicar. Na primeira vez, a tela de Criar conta / Entrar aparece ao abrir."
                               Foreground="{DynamicResource Brush.Text.Tertiary}"
                               FontSize="11" Margin="0,8,0,12" TextWrapping="Wrap"/>

                    <Separator Margin="0,0,0,12"/>

                    <!-- Reparo do acervo. A fila de envio congela o patch no momento da edição, então
                         os equipamentos cadastrados numa versão antiga subiram SEM o vínculo com a
                         credencial e continuariam assim para sempre no outro PC. Este botão reenvia o
                         acervo pelo caminho de update normal, que monta o patch completo de hoje.
                         Some inteiro sem nuvem ativa — não há para onde reenviar. -->
                    <StackPanel x:Name="ResyncSection"
                                Visibility="{Binding CanResync, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Reenviar tudo para a nuvem" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock Text="Use quando o outro PC lista as credenciais no Chaveiro mas, ao conectar, diz que o equipamento não tem credencial. Equipamentos cadastrados antes da nuvem subiram sem esse vínculo; só reenviando ele chega ao outro PC."
                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                   FontSize="{DynamicResource Font.Size.Caption}"
                                   TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <Button x:Name="ResyncButton" Content="Reenviar tudo para a nuvem…"
                                Command="{Binding ResyncCommand}"
                                HorizontalAlignment="Left" Padding="10,4"/>

                        <Border x:Name="ResyncConfirmPanel" Margin="0,10,0,0" Padding="12"
                                Background="{DynamicResource Brush.Bg.Canvas}"
                                BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource Radius.Control}"
                                Visibility="{Binding IsResyncConfirmVisible, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="Confirmar o reenvio?" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="Nada é alterado nem apagado neste PC. O RemoteOps apenas envia de novo, para a nuvem, os grupos, equipamentos e credenciais que já estão aqui — completos desta vez. Com centenas de equipamentos pode levar alguns minutos."
                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                           FontSize="{DynamicResource Font.Size.Caption}"
                                           TextWrapping="Wrap" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Sim, reenviar" Command="{Binding ConfirmResyncCommand}"
                                            Style="{DynamicResource Button.Primary}" Padding="10,4" Margin="0,0,8,0"/>
                                    <Button Content="Cancelar" Command="{Binding CancelResyncCommand}" Padding="10,4"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock x:Name="ResyncStatusText" Text="{Binding ResyncStatus}"
                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                   TextWrapping="Wrap" Margin="0,8,0,0"
                                   Visibility="{Binding HasResyncStatus, Converter={StaticResource BoolToVis}}"/>

                        <!-- Separador DENTRO da seção: sem nuvem ela some inteira e não sobra um par
                             de linhas coladas antes do 2FA. -->
                        <Separator Margin="0,12,0,12"/>
                    </StackPanel>

                    <!-- Equipe (Fatia 1). Some inteira sem nuvem ativa: sem servidor não há convite
                         nem membro, e um botão que só sabe dizer "indisponível" é ruído. -->
                    <StackPanel x:Name="TeamSection"
                                Visibility="{Binding CanManageTeam, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Equipe" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock Text="Um cofre compartilhado: clientes e equipamentos cadastrados por várias pessoas e sincronizados entre todas. O convite tem duas metades — o link vai por e-mail, o código vai por outro canal."
                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                   FontSize="{DynamicResource Font.Size.Caption}"
                                   TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <!-- Primeiro botão e único em destaque: ver COM QUEM o cofre é
                                 compartilhado é o que o operador procura ao abrir esta seção; o
                                 convite é uma ação de dentro dessa tela. -->
                            <Button x:Name="ManageTeamButton" Content="Ver a equipe…"
                                    Command="{Binding ManageTeamCommand}"
                                    Style="{DynamicResource Button.Primary}"
                                    Padding="10,4" Margin="0,0,8,0"/>
                            <Button x:Name="InviteToTeamButton" Content="Convidar alguém…"
                                    Command="{Binding InviteToTeamCommand}" Padding="10,4" Margin="0,0,8,0"/>
                            <Button x:Name="JoinTeamButton" Content="Tenho um convite…"
                                    Command="{Binding JoinTeamCommand}" Padding="10,4"/>
                        </StackPanel>

                        <!-- Separador DENTRO da seção, pelo mesmo motivo do bloco de reenvio acima. -->
                        <Separator Margin="0,12,0,12"/>
                    </StackPanel>

                    <TextBlock Text="Verificação em duas etapas (2FA)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="Exige um código do seu aplicativo autenticador ao entrar na conta da nuvem. Protege o acesso ao servidor; não altera a senha do cofre."
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <Button Content="Configurar verificação em duas etapas…"
                            Command="{Binding ManageMfaCommand}"
                            HorizontalAlignment="Left" Padding="10,4"
                            IsEnabled="{Binding CanManageMfa}"/>
                    <TextBlock Text="Disponível quando você está conectado a uma conta na nuvem."
                               Foreground="{DynamicResource Brush.Text.Tertiary}"
                               FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Ferramentas">
                <StackPanel Margin="12">
                    <TextBlock Text="WinBox" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="Aponte o executável do WinBox. O RemoteOps calcula e fixa o SHA-256; no launch, valida o arquivo (fail-closed se o hash divergir)."
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <TextBlock Text="Caminho do executável" FontSize="11"
                               Foreground="{DynamicResource Brush.Text.Tertiary}" Margin="0,0,0,2"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" IsReadOnly="True"
                                 Text="{Binding WinBoxExePath, Mode=OneWay, TargetNullValue='(não configurado)'}"
                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="Procurar…" Click="BrowseWinBox_Click"
                                Padding="10,4"/>
                    </Grid>

                    <TextBlock Text="SHA-256 fixado" FontSize="11"
                               Foreground="{DynamicResource Brush.Text.Tertiary}" Margin="0,0,0,2"/>
                    <TextBox IsReadOnly="True" FontFamily="Consolas"
                             Text="{Binding WinBoxSha256, Mode=OneWay, TargetNullValue='(nenhum)'}"
                             TextWrapping="Wrap" Margin="0,0,0,8"/>

                    <Button Content="Re-fixar hash" Click="RepinWinBox_Click"
                            HorizontalAlignment="Left" Padding="10,4"
                            IsEnabled="{Binding HasWinBox}"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Novidades">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12">
                    <StackPanel>
                        <TextBlock Text="Sem novidades para mostrar."
                                   Foreground="{DynamicResource Brush.Text.Secondary}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Changelog.HasEntries}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding Changelog.Entries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,12" Padding="12"
                                            Background="{DynamicResource Brush.Bg.Canvas}"
                                            BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                            BorderThickness="1"
                                            CornerRadius="{DynamicResource Radius.Control}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBlock Text="{Binding Version}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Date}" Margin="8,0,0,0"
                                                           Foreground="{DynamicResource Brush.Text.Tertiary}"/>
                                                <Border Margin="8,0,0,0" Padding="6,1"
                                                        Background="{DynamicResource Brush.Accent.Muted}"
                                                        CornerRadius="8"
                                                        Visibility="{Binding IsNew, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="novo" FontSize="10"
                                                               Foreground="{DynamicResource Brush.Accent.Base}"/>
                                                </Border>
                                            </StackPanel>
                                            <ItemsControl ItemsSource="{Binding Highlights}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,1"
                                                                   Foreground="{DynamicResource Brush.Text.Secondary}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Problemas">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12">
                    <StackPanel DataContext="{Binding BugReport}">
                        <TextBlock Text="Título" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                        <TextBlock Text="Descrição" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="90"
                                 VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"/>
                        <CheckBox Content="Incluir diagnósticos (versão, sistema, últimas linhas de log)"
                                  IsChecked="{Binding IncludeDiagnostics}" Margin="0,0,0,8"/>
                        <Expander x:Name="Preview" Header="Ver o que será anexado" Margin="0,0,0,10"
                                  Expanded="Preview_Expanded">
                            <TextBox Text="{Binding PreviewText, Mode=OneWay}" IsReadOnly="True"
                                     FontFamily="Consolas" TextWrapping="Wrap"
                                     MinHeight="80" MaxHeight="160" VerticalScrollBarVisibility="Auto"/>
                        </Expander>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Enviar por e-mail" Command="{Binding SubmitCommand}"
                                    Style="{DynamicResource Button.Primary}" Padding="10,4" Margin="0,0,8,0"/>
                            <Button Content="Copiar" Command="{Binding CopyCommand}" Padding="10,4"/>
                        </StackPanel>
                        <TextBlock Text="{Binding StatusMessage}" Margin="0,8,0,0"
                                   Foreground="{DynamicResource Brush.Text.Secondary}" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Atualização">
                <StackPanel Margin="12">
                    <TextBlock Text="{Binding VersionText}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Verificar agora" Command="{Binding CheckForUpdatesCommand}"
                                Padding="10,4" Margin="0,0,8,0"/>
                        <Button Content="Baixar e instalar" Command="{Binding ApplyUpdateCommand}"
                                Style="{DynamicResource Button.Primary}" Padding="10,4"
                                Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                    <TextBlock Text="A instalação baixa a nova versão e reinicia o RemoteOps automaticamente."
                               Foreground="{DynamicResource Brush.Text.Tertiary}"
                               FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Sobre">
                <StackPanel Margin="12">
                    <TextBlock Text="RemoteOps Desktop" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding VersionText}" Foreground="{DynamicResource Brush.Text.Secondary}"/>
                    <TextBlock Text="Console de operação de rede." Margin="0,8,0,0"
                               Foreground="{DynamicResource Brush.Text.Secondary}"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
