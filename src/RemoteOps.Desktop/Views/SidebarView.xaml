<UserControl x:Class="RemoteOps.Desktop.Views.SidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RemoteOps.Desktop.ViewModels">

    <DockPanel>
        <TextBlock DockPanel.Dock="Top"
                   Text="Grupos"
                   FontWeight="SemiBold"
                   Margin="8,8,8,4"
                   Foreground="{DynamicResource Brush.Text.Secondary}"/>

        <!-- Adicionar grupo -->
        <Grid DockPanel.Dock="Bottom" Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding NewGroupName, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Nome do novo grupo"
                     Margin="0,0,4,0"/>
            <Button Grid.Column="1"
                    Content="+"
                    Command="{Binding AddGroupCommand}"
                    ToolTip="Adicionar grupo"
                    Width="28" Height="28"/>
        </Grid>

        <!-- Botão deletar grupo -->
        <Button DockPanel.Dock="Bottom"
                Content="Remover grupo selecionado"
                Command="{Binding DeleteGroupCommand}"
                Margin="4,0,4,4"
                Padding="4,2"/>

        <!-- Árvore de grupos -->
        <TreeView ItemsSource="{Binding Groups}"
                  SelectedItemChanged="OnGroupSelected"
                  BorderThickness="0"
                  Background="Transparent">
            <TreeView.Resources>
                <HierarchicalDataTemplate DataType="{x:Type vm:AssetGroupViewModel}"
                                          ItemsSource="{Binding Children}">
                    <TextBlock Text="{Binding Name}" Padding="2"/>
                </HierarchicalDataTemplate>
            </TreeView.Resources>
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>
    </DockPanel>
</UserControl>
