<UserControl x:Class="RemoteOps.Desktop.Views.KeychainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DockPanel Background="{DynamicResource Brush.Bg.Surface}">

        <TextBlock DockPanel.Dock="Top"
                   Text="Keychain"
                   Style="{DynamicResource Text.Title}"
                   Margin="{DynamicResource Thickness.PanelPadding}"/>

        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,0,8,8">
            <Button Content="Add credential" Click="Add_Click" Padding="8,3" Margin="0,0,6,0"/>
            <Button Content="Edit" Click="Edit_Click" Padding="8,3" Margin="0,0,6,0"/>
            <Button Content="Change password" Click="ChangePassword_Click" Padding="8,3" Margin="0,0,6,0"/>
            <Button Content="Replace key" Click="ReplaceKey_Click" Padding="8,3" Margin="0,0,6,0"
                    ToolTip="Substitui a chave privada (credenciais SSH key)"/>
            <Button Content="Change passphrase" Click="ChangePassphrase_Click" Padding="8,3" Margin="0,0,6,0"
                    ToolTip="Troca a passphrase da chave (credenciais SSH key)"/>
            <Button Content="Delete" Click="Delete_Click" Padding="8,3"/>
        </StackPanel>

        <!-- Empty state -->
        <TextBlock Text="No credentials in this workspace yet. Click “Add credential”."
                   TextWrapping="Wrap"
                   Margin="24"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center">
            <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource Text.Secondary}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Credentials.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <DataGrid ItemsSource="{Binding Credentials}"
                  SelectedItem="{Binding SelectedCredential, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  SelectionMode="Single"
                  BorderThickness="0"
                  CanUserResizeRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name"     Binding="{Binding Name}"              Width="*"/>
                <DataGridTextColumn Header="Type"     Binding="{Binding Type}"              Width="120"/>
                <DataGridTextColumn Header="Username" Binding="{Binding Metadata.Username}" Width="160"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
