<UserControl x:Class="RemoteOps.Desktop.Views.InspectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DockPanel>
        <TextBlock DockPanel.Dock="Top"
                   Text="Inspector"
                   Style="{DynamicResource Text.Caption}"
                   FontWeight="SemiBold"
                   Margin="8,8,8,4"/>

        <!-- Placeholder quando nada selecionado -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Selecione um host para ver detalhes."
                   Margin="8,4"
                   TextWrapping="Wrap">
            <!-- Style e o DataTrigger de Visibility precisam ficar num único
                 <TextBlock.Style> — um atributo Style="" e um bloco <TextBlock.Style> juntos
                 no mesmo elemento são erro de compilação XAML (MC3024, propriedade definida
                 duas vezes). BasedOn usa StaticResource porque é resolvido ao montar a árvore
                 de Style, não em tempo de render como o DynamicResource do resto do sistema
                 de design. -->
            <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource Text.Secondary}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasAsset}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Painel de detalhes -->
        <StackPanel Margin="8">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasAsset}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <TextBlock Text="{Binding Asset.Name}" Style="{DynamicResource Text.Title}" Margin="0,0,0,8"/>

            <TextBlock Text="Ações rápidas:" Style="{DynamicResource Text.BodyStrong}" Margin="0,0,0,4"/>
            <WrapPanel Margin="0,0,0,4">
                <Button Command="{Binding OpenSessionCommand}" CommandParameter="ssh" Margin="0,0,4,4" Padding="8,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource Icon.Connect}" Style="{DynamicResource Icon.Style}" Margin="0,0,4,0"/>
                        <TextBlock Text="SSH"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding OpenSessionCommand}" CommandParameter="telnet" Margin="0,0,4,4" Padding="8,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource Icon.Connect}" Style="{DynamicResource Icon.Style}" Margin="0,0,4,0"/>
                        <TextBlock Text="Telnet"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding OpenSessionCommand}"
                        CommandParameter="rdp"
                        Margin="0,0,4,4" Padding="8,2">
                    <Button.Style>
                        <!-- BasedOn obrigatório: Button.Style local aqui substituiria por
                             completo o Style implícito escuro de Themes/Controls/Buttons.xaml. -->
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CanOpenRdp}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource Icon.RemoteDesktop}" Style="{DynamicResource Icon.Style}" Margin="0,0,4,0"/>
                        <TextBlock Text="RDP"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding OpenWinBoxCommand}"
                        Margin="0,0,4,4" Padding="8,2">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMikroTikHost}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource Icon.Network}" Style="{DynamicResource Icon.Style}" Margin="0,0,4,0"/>
                        <TextBlock Text="Abrir WinBox"/>
                    </StackPanel>
                </Button>
            </WrapPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasWinBoxError}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="{DynamicResource Icon.Warning}"
                           Style="{DynamicResource Icon.Style}"
                           Foreground="{DynamicResource Brush.Status.Error}"
                           VerticalAlignment="Top"
                           Margin="0,1,4,0"/>
                <TextBlock Text="{Binding WinBoxError}"
                           Style="{DynamicResource Text.Caption}"
                           Foreground="{DynamicResource Brush.Status.Error}"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <Separator Margin="0,4"/>

            <!-- Adicionar endpoint -->
            <TextBlock Text="Adicionar endpoint:" Style="{DynamicResource Text.BodyStrong}" Margin="0,4,0,4"/>
            <ComboBox SelectedValuePath="Content"
                      SelectedValue="{Binding NewEndpointProtocol, Mode=TwoWay}"
                      Margin="0,0,0,4">
                <ComboBoxItem Content="ssh"/>
                <ComboBoxItem Content="telnet"/>
                <ComboBoxItem Content="rdp"/>
                <ComboBoxItem Content="mikrotik"/>
            </ComboBox>
            <TextBox Text="{Binding NewEndpointAddress, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="IP ou FQDN"
                     Margin="0,0,0,4"/>
            <TextBox Text="{Binding NewEndpointPort, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Porta"
                     Margin="0,0,0,4"/>
            <Button Content="Adicionar endpoint"
                    Command="{Binding AddEndpointCommand}"
                    Style="{DynamicResource Button.Primary}"
                    Padding="8,2"/>

            <Separator Margin="0,8"/>

            <!-- Credencial -->
            <TextBlock Text="Credencial:" Style="{DynamicResource Text.BodyStrong}" Margin="0,0,0,4"/>
            <TextBlock Text="(nenhuma configurada)" Foreground="{DynamicResource Brush.Text.Tertiary}" FontStyle="Italic"/>
            <TextBlock Text="Senha nunca exibida aqui." Style="{DynamicResource Text.Micro}" Margin="0,2,0,0"/>
        </StackPanel>
    </DockPanel>
</UserControl>
