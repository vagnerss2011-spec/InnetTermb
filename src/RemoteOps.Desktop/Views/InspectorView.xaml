<UserControl x:Class="RemoteOps.Desktop.Views.InspectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DockPanel>
        <TextBlock DockPanel.Dock="Top"
                   Text="Inspector"
                   FontWeight="SemiBold"
                   Margin="8,8,8,4"
                   Foreground="#555"/>

        <!-- Placeholder quando nada selecionado -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Selecione um host para ver detalhes."
                   Foreground="#888"
                   Margin="8,4"
                   TextWrapping="Wrap">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasAsset}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Painel de detalhes -->
        <StackPanel Margin="8">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasAsset}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <TextBlock Text="{Binding Asset.Name}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>

            <TextBlock Text="Ações rápidas:" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <WrapPanel Margin="0,0,0,4">
                <Button Content="SSH"     Command="{Binding OpenSessionCommand}" CommandParameter="ssh"      Margin="0,0,4,4" Padding="8,2"/>
                <Button Content="Telnet"  Command="{Binding OpenSessionCommand}" CommandParameter="telnet"   Margin="0,0,4,4" Padding="8,2"/>
                <Button Content="RDP"     Command="{Binding OpenSessionCommand}" CommandParameter="rdp"      Margin="0,0,4,4" Padding="8,2"/>
                <Button Content="Abrir WinBox"
                        Command="{Binding OpenWinBoxCommand}"
                        Margin="0,0,4,4" Padding="8,2">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMikroTikHost}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </WrapPanel>
            <TextBlock Text="{Binding WinBoxError}"
                       Foreground="Red"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8"
                       FontSize="11">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasWinBoxError}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Separator Margin="0,4"/>

            <!-- Adicionar endpoint -->
            <TextBlock Text="Adicionar endpoint:" FontWeight="SemiBold" Margin="0,4,0,4"/>
            <ComboBox SelectedValuePath="Content"
                      SelectedValue="{Binding NewEndpointProtocol, Mode=TwoWay}"
                      Margin="0,0,0,4">
                <ComboBoxItem Content="ssh"/>
                <ComboBoxItem Content="telnet"/>
                <ComboBoxItem Content="rdp"/>
                <ComboBoxItem Content="mikrotik"/>
            </ComboBox>
            <TextBox Text="{Binding NewEndpointAddress, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="IP ou FQDN"
                     Margin="0,0,0,4"/>
            <TextBox Text="{Binding NewEndpointPort, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Porta"
                     Margin="0,0,0,4"/>
            <Button Content="Adicionar endpoint"
                    Command="{Binding AddEndpointCommand}"
                    Padding="8,2"/>

            <Separator Margin="0,8"/>

            <!-- Credencial -->
            <TextBlock Text="Credencial:" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Text="(nenhuma configurada)" Foreground="#888" FontStyle="Italic"/>
            <TextBlock Text="Senha nunca exibida aqui." Foreground="#888" FontSize="10" Margin="0,2,0,0"/>
        </StackPanel>
    </DockPanel>
</UserControl>
