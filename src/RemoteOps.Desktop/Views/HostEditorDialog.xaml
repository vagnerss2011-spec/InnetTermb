<Window x:Class="RemoteOps.Desktop.Views.HostEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:assets="clr-namespace:RemoteOps.Contracts.Assets;assembly=RemoteOps.Contracts"
        xmlns:conv="clr-namespace:RemoteOps.Desktop.Converters"
        Title="{Binding Title}" Height="500" Width="720" MinWidth="640" MinHeight="460"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrips"
        Background="{DynamicResource Brush.Bg.App}"
        Foreground="{DynamicResource Brush.Text.Primary}"
        FontFamily="{DynamicResource Font.Family.Base}"
        FontSize="{DynamicResource Font.Size.Body}">
    <Window.Resources>
        <conv:EndpointAddressConverter x:Key="EndpointAddressConverter"/>
    </Window.Resources>
    <DockPanel Margin="16">

        <!-- Botões Salvar/Cancelar -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancelar" IsCancel="True" MinWidth="88" Padding="10,4" Margin="0,0,8,0"/>
            <Button Content="Salvar" Command="{Binding SaveCommand}"
                    Style="{DynamicResource Button.Primary}" MinWidth="88" Padding="10,4"/>
        </StackPanel>

        <!-- Nome do host -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Nome" Style="{DynamicResource Text.BodyStrong}" Margin="0,0,0,4"/>
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

        <!-- Linha "adicionar endpoint" (com rótulos — o seletor de protocolo sem
             rótulo/seleção era interpretado como "checkboxes soltas" na edição) -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Protocolo" FontSize="11"
                       Foreground="{DynamicResource Brush.Text.Tertiary}" Margin="0,0,8,2"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="Endereço" FontSize="11"
                       Foreground="{DynamicResource Brush.Text.Tertiary}" Margin="0,0,8,2"/>
            <TextBlock Grid.Row="0" Grid.Column="2" Text="Porta" FontSize="11"
                       Foreground="{DynamicResource Brush.Text.Tertiary}" Margin="0,0,8,2"/>
            <TextBlock Grid.Row="0" Grid.Column="3" Text="Credencial (opcional)" FontSize="11"
                       Foreground="{DynamicResource Brush.Text.Tertiary}" Margin="0,0,8,2"/>

            <ComboBox Grid.Row="1" Grid.Column="0"
                      SelectedValuePath="Content"
                      SelectedValue="{Binding NewEndpointProtocol, Mode=TwoWay}"
                      Margin="0,0,8,0" VerticalAlignment="Center">
                <ComboBoxItem Content="ssh"/>
                <ComboBoxItem Content="telnet"/>
                <ComboBoxItem Content="rdp"/>
                <ComboBoxItem Content="mikrotik"/>
            </ComboBox>

            <TextBox Grid.Row="1" Grid.Column="1" MinWidth="140"
                     Text="{Binding NewEndpointAddress, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Endereço: IPv4 (10.0.0.1), IPv6 (2001:db8::1, com ou sem colchetes) ou FQDN (sn.mynetname.net)"
                     Margin="0,0,8,0" VerticalAlignment="Center"/>

            <TextBox Grid.Row="1" Grid.Column="2"
                     Text="{Binding NewEndpointPort, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Porta"
                     Margin="0,0,8,0" VerticalAlignment="Center"/>

            <ComboBox Grid.Row="1" Grid.Column="3"
                      ItemsSource="{Binding AvailableCredentials}"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"
                      SelectedValue="{Binding NewEndpointCredentialId, Mode=TwoWay}"
                      ToolTip="Credencial (opcional) — crie na aba Keychain"
                      Margin="0,0,8,0" VerticalAlignment="Center"/>

            <Button Grid.Row="1" Grid.Column="4" Content="Adicionar endpoint"
                    Command="{Binding AddEndpointCommand}"
                    Padding="10,4" VerticalAlignment="Center"/>
        </Grid>

        <!-- Lista de endpoints -->
        <TextBlock DockPanel.Dock="Top" Text="Endpoints" Style="{DynamicResource Text.BodyStrong}" Margin="0,0,0,4"/>
        <ListBox ItemsSource="{Binding Endpoints}"
                 BorderThickness="1"
                 BorderBrush="{DynamicResource Brush.Border.Default}"
                 Background="{DynamicResource Brush.Bg.Canvas}">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type assets:Endpoint}">
                    <Grid Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding Converter="{StaticResource EndpointAddressConverter}">
                                    <Binding Path="Protocol"/>
                                    <Binding Path="Ipv4"/>
                                    <Binding Path="Ipv6"/>
                                    <Binding Path="Fqdn"/>
                                    <Binding Path="Port"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <Button Grid.Column="1" Content="Remover"
                                Style="{DynamicResource Button.Danger}"
                                Command="{Binding DataContext.RemoveEndpointCommand,
                                          RelativeSource={RelativeSource AncestorType=ListBox}}"
                                CommandParameter="{Binding}"
                                Padding="8,2"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
