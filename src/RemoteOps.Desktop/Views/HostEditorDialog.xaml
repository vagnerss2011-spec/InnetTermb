<Window x:Class="RemoteOps.Desktop.Views.HostEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:assets="clr-namespace:RemoteOps.Contracts.Assets;assembly=RemoteOps.Contracts"
        xmlns:conv="clr-namespace:RemoteOps.Desktop.Converters"
        Title="{Binding Title}" Height="500" Width="820" MinWidth="720" MinHeight="460"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource Brush.Bg.App}"
        Foreground="{DynamicResource Brush.Text.Primary}"
        FontFamily="{DynamicResource Font.Family.Base}"
        FontSize="{DynamicResource Font.Size.Body}">
    <Window.Resources>
        <conv:EndpointAddressConverter x:Key="EndpointAddressConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <DockPanel Margin="16">

        <!-- Botões Salvar/Cancelar -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancelar" IsCancel="True" MinWidth="88" Padding="10,4" Margin="0,0,8,0"/>
            <Button Content="Salvar" Command="{Binding SaveCommand}"
                    Style="{DynamicResource Button.Primary}" MinWidth="88" Padding="10,4"/>
        </StackPanel>

        <!-- Nome do host -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Nome" Style="{DynamicResource Text.BodyStrong}" Margin="0,0,0,4"/>
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

        <!-- Área "adicionar endpoint": linha 1 (protocolo/endereço/porta/SSH), linha 2 (credencial:
             Keychain compartilhada OU senha só deste dispositivo), botão adicionar. -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Protocolo" FontSize="11"
                           Foreground="{DynamicResource Brush.Text.Tertiary}" Margin="0,0,8,2"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="Endereço" FontSize="11"
                           Foreground="{DynamicResource Brush.Text.Tertiary}" Margin="0,0,8,2"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Porta" FontSize="11"
                           Foreground="{DynamicResource Brush.Text.Tertiary}" Margin="0,0,8,2"/>
                <TextBlock Grid.Row="0" Grid.Column="3" Text="Segurança SSH" FontSize="11"
                           Foreground="{DynamicResource Brush.Text.Tertiary}" Margin="0,0,8,2"/>

                <ComboBox Grid.Row="1" Grid.Column="0"
                          SelectedValuePath="Content"
                          SelectedValue="{Binding NewEndpointProtocol, Mode=TwoWay}"
                          Margin="0,0,8,0" VerticalAlignment="Center">
                    <ComboBoxItem Content="ssh"/>
                    <ComboBoxItem Content="telnet"/>
                    <ComboBoxItem Content="rdp"/>
                    <ComboBoxItem Content="mikrotik"/>
                </ComboBox>

                <TextBox Grid.Row="1" Grid.Column="1" MinWidth="140"
                         Text="{Binding NewEndpointAddress, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Endereço: IPv4 (10.0.0.1), IPv6 (2001:db8::1, com ou sem colchetes) ou FQDN (sn.mynetname.net)"
                         Margin="0,0,8,0" VerticalAlignment="Center"/>

                <TextBox Grid.Row="1" Grid.Column="2"
                         Text="{Binding NewEndpointPort, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Porta"
                         Margin="0,0,8,0" VerticalAlignment="Center"/>

                <ComboBox Grid.Row="1" Grid.Column="3"
                          SelectedValuePath="Content"
                          SelectedValue="{Binding NewEndpointSshProfile, Mode=TwoWay}"
                          ToolTip="Automático: conecta em qualquer equipamento (inclusive antigo). Estrito: exige algoritmos modernos (hardening; use em hosts novos)."
                          VerticalAlignment="Center">
                    <ComboBoxItem Content="auto"/>
                    <ComboBoxItem Content="strict"/>
                </ComboBox>
            </Grid>

            <!-- Modo de credencial -->
            <TextBlock Text="Credencial" FontSize="11" Margin="0,10,0,2"
                       Foreground="{DynamicResource Brush.Text.Tertiary}"/>
            <StackPanel Orientation="Horizontal">
                <RadioButton Content="Do Keychain (compartilhada)" GroupName="credMode"
                             IsChecked="{Binding UseKeychainCredential, Mode=TwoWay}"
                             VerticalAlignment="Center"
                             ToolTip="Escolhe uma credencial nomeada do Keychain — use quando vários dispositivos têm o MESMO login."/>
                <RadioButton Content="Senha só deste dispositivo" GroupName="credMode"
                             IsChecked="{Binding UseInlineCredential, Mode=TwoWay}"
                             VerticalAlignment="Center" Margin="18,0,0,0"
                             ToolTip="Usuário e senha digitados aqui, cifrados e presos a este device — não vira item do Keychain."/>
            </StackPanel>

            <!-- Modo Keychain: dropdown das credenciais nomeadas -->
            <ComboBox Margin="0,6,0,0" MaxWidth="360" HorizontalAlignment="Left"
                      Visibility="{Binding UseKeychainCredential, Converter={StaticResource BoolToVis}}"
                      ItemsSource="{Binding AvailableCredentials}"
                      DisplayMemberPath="Name"
                      SelectedValuePath="Id"
                      SelectedValue="{Binding NewEndpointCredentialId, Mode=TwoWay}"
                      ToolTip="Credencial do Keychain (crie na aba Chaveiro)"/>

            <!-- Modo inline: usuário + senha só deste dispositivo -->
            <Grid Margin="0,6,0,0"
                  Visibility="{Binding UseInlineCredential, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Usuário" FontSize="11"
                           Foreground="{DynamicResource Brush.Text.Tertiary}" Margin="0,0,8,2"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="Senha" FontSize="11"
                           Foreground="{DynamicResource Brush.Text.Tertiary}" Margin="0,0,0,2"/>
                <TextBox Grid.Row="1" Grid.Column="0"
                         Text="{Binding NewEndpointInlineUsername, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,8,0" VerticalAlignment="Center"/>
                <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="InlinePasswordField"
                             VerticalAlignment="Center"/>
            </Grid>

            <Button Content="Adicionar endpoint" Click="AddEndpoint_Click"
                    IsEnabled="{Binding CanAddEndpoint}"
                    HorizontalAlignment="Right" Padding="10,4" Margin="0,10,0,0"/>
        </StackPanel>

        <!-- Lista de endpoints -->
        <TextBlock DockPanel.Dock="Top" Text="Endpoints" Style="{DynamicResource Text.BodyStrong}" Margin="0,0,0,4"/>
        <ListBox ItemsSource="{Binding Endpoints}"
                 BorderThickness="1"
                 BorderBrush="{DynamicResource Brush.Border.Default}"
                 Background="{DynamicResource Brush.Bg.Canvas}">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type assets:Endpoint}">
                    <Grid Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding Converter="{StaticResource EndpointAddressConverter}">
                                    <Binding Path="Protocol"/>
                                    <Binding Path="Ipv4"/>
                                    <Binding Path="Ipv6"/>
                                    <Binding Path="Fqdn"/>
                                    <Binding Path="Port"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <Button Grid.Column="1" Content="Remover"
                                Style="{DynamicResource Button.Danger}"
                                Command="{Binding DataContext.RemoveEndpointCommand,
                                          RelativeSource={RelativeSource AncestorType=ListBox}}"
                                CommandParameter="{Binding}"
                                Padding="8,2"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
