<Window x:Class="RemoteOps.Desktop.Views.TeamInviteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}" Height="Auto" Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource Brush.Bg.App}"
        Foreground="{DynamicResource Brush.Text.Primary}"
        FontFamily="{DynamicResource Font.Family.Base}"
        FontSize="{DynamicResource Font.Size.Body}">
    <!--
        Convite do time (Fatia 1). Como na AccountWindow, os controles NÃO levam
        Background/Foreground/BorderBrush locais: o tema define estilo IMPLÍCITO por TargetType, e
        estilo local produz o controle "claro do Aero2" no meio da janela escura.
    -->
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <StackPanel Margin="20">
        <TextBlock Text="{Binding Title}" Style="{DynamicResource Text.TitleLg}" Margin="0,0,0,10"/>

        <!-- ── Fundar o TIME ── -->
        <!--
            O aviso vem ANTES do campo e ANTES do botão, de propósito. Quem tem centenas de clientes
            cadastrados espera vê-los do outro lado; o time é um workspace NOVO e nasce sem nada.
            Frustrar essa expectativa não vira só decepção — vira o operador procurando os
            equipamentos e concluindo que a sincronização quebrou.
        -->
        <StackPanel Visibility="{Binding IsCreateTeamMode, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource Brush.Status.CriticalSurface}"
                    BorderBrush="{DynamicResource Brush.Status.CriticalBase}"
                    BorderThickness="1" CornerRadius="{DynamicResource Radius.Control}"
                    Padding="10,8" Margin="0,0,0,12">
                <TextBlock x:Name="EmptyTeamWarningText" Text="{Binding TeamCreationWarning}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource Brush.Text.Primary}"/>
            </Border>

            <TextBlock Text="Nome do time" Style="{DynamicResource Text.Caption}" Margin="0,0,0,2"/>
            <TextBox x:Name="TeamNameField" Text="{Binding TeamName, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding IsIdle}" Margin="0,0,0,12"/>

            <Button x:Name="CreateTeamButton" Content="Criar o time"
                    Style="{DynamicResource Button.Primary}" IsDefault="True"
                    IsEnabled="{Binding IsIdle}" Click="CreateTeam_Click"
                    Padding="10,6" Margin="0,0,0,12"/>
        </StackPanel>

        <!-- ── Lado de quem CONVIDA ── -->
        <StackPanel Visibility="{Binding IsGenerateMode, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="E-mail de quem você quer convidar" Style="{DynamicResource Text.Caption}"
                       Margin="0,0,0,2"/>
            <TextBox x:Name="EmailField" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding IsIdle}" Margin="0,0,0,10"/>

            <TextBlock Text="Papel no time" Style="{DynamicResource Text.Caption}" Margin="0,0,0,2"/>
            <!-- Lista fechada, e não campo livre: "Tecnico" (sem acento) ou "operator" (minúsculo)
                 viravam um 400 do servidor DEPOIS de o operador já ter ditado o código por telefone.
                 O ComboBoxItem TEM estilo implícito no tema — sem ele o popup cai no Aero2 CLARO e
                 fica texto branco em fundo branco (a mesma classe de defeito da v1.2.24). -->
            <ComboBox x:Name="RoleField" ItemsSource="{Binding RoleOptions}"
                      SelectedValue="{Binding Role}" SelectedValuePath="Id"
                      IsEnabled="{Binding IsIdle}" Margin="0,0,0,4">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Label}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Text="{Binding RoleDescription}" Style="{DynamicResource Text.Caption}"
                       TextWrapping="Wrap" Margin="0,0,0,12"/>

            <Button x:Name="GenerateButton" Content="Gerar convite"
                    Style="{DynamicResource Button.Primary}" IsDefault="True"
                    IsEnabled="{Binding IsIdle}" Click="Generate_Click"
                    Padding="10,6" Margin="0,0,0,12"/>

            <!-- O código sorteado + o aviso que o torna seguro. Só aparecem depois de gerar. -->
            <StackPanel Visibility="{Binding HasGeneratedCode, Converter={StaticResource BoolToVis}}">
                <Border Background="{DynamicResource Brush.Status.CriticalSurface}"
                        BorderBrush="{DynamicResource Brush.Status.CriticalBase}"
                        BorderThickness="1" CornerRadius="{DynamicResource Radius.Control}"
                        Padding="10,8" Margin="0,0,0,10">
                    <TextBlock x:Name="WarningText" Text="{Binding Warning}" TextWrapping="Wrap"
                               Foreground="{DynamicResource Brush.Text.Primary}"/>
                </Border>

                <TextBlock Text="Código do convite" Style="{DynamicResource Text.Caption}" Margin="0,0,0,2"/>
                <Border Background="{DynamicResource Brush.Bg.Surface}"
                        BorderBrush="{DynamicResource Brush.Border.Default}"
                        BorderThickness="1" CornerRadius="{DynamicResource Radius.Surface}"
                        Padding="12" Margin="0,0,0,8">
                    <TextBlock x:Name="GeneratedCodeText" Text="{Binding GeneratedCode}"
                               Style="{DynamicResource Text.Mono}" TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </Border>

                <TextBlock Text="Identificador do convite (esse pode ir por e-mail)"
                           Style="{DynamicResource Text.Caption}" Margin="0,0,0,2"/>
                <TextBox x:Name="GeneratedInviteIdField" Text="{Binding InviteId, Mode=OneWay}"
                         IsReadOnly="True" Margin="0,0,0,8"/>

                <Button Content="Copiar código" Command="{Binding CopyCodeCommand}"
                        HorizontalAlignment="Center" Padding="10,4" Margin="0,0,0,10"/>
            </StackPanel>
        </StackPanel>

        <!-- ── Lado de quem ENTRA ── -->
        <StackPanel Visibility="{Binding IsAcceptMode, Converter={StaticResource BoolToVis}}">
            <TextBlock Style="{DynamicResource Text.Caption}" TextWrapping="Wrap" Margin="0,0,0,12"
                       Text="O identificador está no e-mail do convite. O código vem por outro canal — WhatsApp, telefone ou pessoalmente. Você precisa dos dois."/>

            <TextBlock Text="Identificador do convite" Style="{DynamicResource Text.Caption}" Margin="0,0,0,2"/>
            <TextBox x:Name="InviteIdField" Text="{Binding InviteId, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding IsIdle}" Margin="0,0,0,10"/>

            <TextBlock Text="Código do convite" Style="{DynamicResource Text.Caption}" Margin="0,0,0,2"/>
            <TextBox x:Name="CodeField" Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding IsIdle}" Margin="0,0,0,12"/>

            <Button x:Name="AcceptButton" Content="Entrar no time"
                    Style="{DynamicResource Button.Primary}" IsDefault="True"
                    IsEnabled="{Binding IsIdle}" Click="Accept_Click"
                    Padding="10,6" Margin="0,0,0,12"/>
        </StackPanel>

        <Border x:Name="ErrorBox" Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                Background="{DynamicResource Brush.Status.CriticalSurface}"
                BorderBrush="{DynamicResource Brush.Status.CriticalBase}"
                BorderThickness="1" CornerRadius="{DynamicResource Radius.Control}"
                Padding="10,6" Margin="0,0,0,10">
            <TextBlock x:Name="ErrorText" Text="{Binding ErrorMessage}" TextWrapping="Wrap"
                       Foreground="{DynamicResource Brush.Text.Primary}"/>
        </Border>

        <TextBlock x:Name="StatusText" Text="{Binding StatusMessage}"
                   Style="{DynamicResource Text.Caption}" TextWrapping="Wrap"
                   Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}"/>
    </StackPanel>
</Window>
