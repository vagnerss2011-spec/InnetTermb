<Window x:Class="RemoteOps.Desktop.Views.SyncConflictsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Alterações que não subiram"
        Width="640"
        MinWidth="480"
        Height="520"
        MinHeight="320"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Bg.Base}"
        Foreground="{DynamicResource Brush.Text.Primary}"
        FontFamily="Segoe UI">
    <!-- Redimensionável e com ScrollViewer de propósito: a lição das 4 janelas de tamanho fixo que
         cortavam conteúdo em notebook 1366x768 a 125-150% (ver inventário de responsividade). -->
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Alterações que não subiram para a nuvem"
                       Style="{DynamicResource Text.Title}"
                       TextWrapping="Wrap"/>
            <TextBlock Style="{DynamicResource Text.Body}"
                       Foreground="{DynamicResource Brush.Text.Secondary}"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0"
                       Text="Estes itens já tinham sido alterados em outro computador. Para não sobrescrever o trabalho de lá, a versão da nuvem prevaleceu e a alteração feita aqui foi descartada. Se alguma delas ainda importa, refaça a alteração agora — ela vai subir normalmente."/>
        </StackPanel>

        <Border Grid.Row="1"
                BorderBrush="{DynamicResource Brush.Border.Default}"
                BorderThickness="1"
                Background="{DynamicResource Brush.Bg.Surface}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ConflictList" Margin="4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,8" Margin="2">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding TipoTexto}"
                                                   Style="{DynamicResource Text.Body}"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="  ·  "
                                                   Style="{DynamicResource Text.Body}"
                                                   Foreground="{DynamicResource Brush.Text.Tertiary}"/>
                                        <TextBlock Text="{Binding QuandoTexto}"
                                                   Style="{DynamicResource Text.Caption}"
                                                   Foreground="{DynamicResource Brush.Text.Tertiary}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding MotivoTexto}"
                                               Style="{DynamicResource Text.Caption}"
                                               Foreground="{DynamicResource Brush.Text.Secondary}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <TextBlock x:Name="EmptyLabel"
                   Grid.Row="1"
                   Text="Nenhuma alteração pendente de aviso."
                   Style="{DynamicResource Text.Body}"
                   Foreground="{DynamicResource Brush.Text.Tertiary}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Visibility="Collapsed"/>

        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <Button x:Name="CloseButton"
                    DockPanel.Dock="Right"
                    Content="Fechar"
                    MinWidth="100"
                    Click="Close_Click"/>
            <Button x:Name="DismissButton"
                    DockPanel.Dock="Right"
                    Content="Já vi, pode limpar"
                    Style="{DynamicResource Button.Primary}"
                    MinWidth="150"
                    Margin="0,0,8,0"
                    Click="Dismiss_Click"/>
            <TextBlock Style="{DynamicResource Text.Caption}"
                       Foreground="{DynamicResource Brush.Text.Tertiary}"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"
                       Text="Limpar só remove este aviso — não desfaz nem refaz nada. Um conflito novo volta a aparecer."/>
        </DockPanel>
    </Grid>
</Window>
