<UserControl x:Class="RemoteOps.Desktop.Views.DeviceIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="16" Height="16"
             SnapsToDevicePixels="True">
    <Grid>
        <!-- Logo do vendor (assets/logos/<vendor>.png), quando existir. -->
        <Image x:Name="LogoImage" Stretch="Uniform" Visibility="Collapsed"
               RenderOptions.BitmapScalingMode="HighQuality"/>
        <!-- Fallback: glifo VETORIAL do papel, tingido pela cor do vendor. -->
        <Path x:Name="GlyphPath" Stretch="Uniform" Margin="1"
              StrokeThickness="1.3" StrokeLineJoin="Round"
              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
    </Grid>
</UserControl>
