<UserControl x:Class="RemoteOps.Desktop.Views.BrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RemoteOps.Desktop.ViewModels"
             xmlns:views="clr-namespace:RemoteOps.Desktop.Views">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Item do rail (Hosts/Keychain/Logs): RadioButton sem moldura padrão, ícone
             empilhado sobre um rótulo curto; "ativo" muda fundo/cor via IsChecked. -->
        <Style x:Key="Rail.Item" TargetType="RadioButton">
            <Setter Property="GroupName" Value="RailSection"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Chrome"
                                Background="Transparent"
                                Margin="8,4"
                                CornerRadius="{DynamicResource Radius.Control}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Brush.Bg.Hover}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Brush.Bg.Selected}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Base}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <DockPanel>

        <!-- Barra de status do cloud sync (Fase 2, item B): indicador Offline/Sincronizando/
             Sincronizado/Erro + botão "Sincronizar agora" (push+pull). DataContext = Sync (nunca null).
             Botão desabilitado sem nuvem (SyncNowCommand.CanExecute = HasCloud && !IsBusy) — offline-first. -->
        <Border DockPanel.Dock="Bottom"
                DataContext="{Binding Sync}"
                Background="{DynamicResource Brush.Bg.Surface}"
                BorderBrush="{DynamicResource Brush.Border.Subtle}"
                BorderThickness="0,1,0,0"
                Padding="12,5">
            <Border.Resources>
                <!-- Cor do ponto pelo estado. Padrão = Idle (Offline); triggers pintam o resto. -->
                <Style x:Key="Sync.Dot" TargetType="Ellipse">
                    <Setter Property="Width" Value="9"/>
                    <Setter Property="Height" Value="9"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="Margin" Value="0,0,7,0"/>
                    <Setter Property="Fill" Value="{DynamicResource Brush.Status.Idle}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSyncing}" Value="True">
                            <Setter Property="Fill" Value="{DynamicResource Brush.Status.Pending}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsSynced}" Value="True">
                            <Setter Property="Fill" Value="{DynamicResource Brush.Status.Online}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsError}" Value="True">
                            <Setter Property="Fill" Value="{DynamicResource Brush.Status.Error}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>

                <!-- Carimbo do "Sincronizar agora": discreto no sucesso, gritante na falha. A cor é o
                     que separa "deu" de "não deu" de relance — sem o trigger, a falha teria a mesma
                     cara apagada do sucesso. Tipografia por token (BasedOn), nenhum tamanho literal. -->
                <Style x:Key="Sync.Outcome" TargetType="TextBlock" BasedOn="{StaticResource Text.Caption}">
                    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Tertiary}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SyncOutcomeFailed}" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Status.Error}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Resources>

            <DockPanel LastChildFill="False">
                <!-- Indicador à esquerda: ponto colorido + texto; tooltip acionável em pt-BR. -->
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Left"
                            VerticalAlignment="Center"
                            ToolTip="{Binding StatusDetail}">
                    <Ellipse Style="{StaticResource Sync.Dot}"/>
                    <TextBlock Text="{Binding StatusText}"
                               Style="{DynamicResource Text.Caption}"
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Como as alterações da outra ponta chegam: "Tempo real" (canal de hints) ou
                     "Periódico" (só no próximo tick do laço). Fica aqui porque "Sincronizado" tem a
                     mesma cara nos dois casos, e é a única pista do operador em campo — a URL do hub
                     leva o JWT e não pode ir pro log (ADR-013). Escondido sem nuvem: ali o modo do
                     canal não quer dizer nada. Tooltip próprio, senão o do status cobriria os dois. -->
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Left"
                            VerticalAlignment="Center"
                            Margin="10,0,0,0"
                            Visibility="{Binding HasCloud, Converter={StaticResource BoolToVis}}"
                            ToolTip="{Binding ChannelDetail}">
                    <TextBlock Text="·"
                               Style="{DynamicResource Text.Caption}"
                               Foreground="{DynamicResource Brush.Text.Tertiary}"
                               Margin="0,0,10,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ChannelText}"
                               Style="{DynamicResource Text.Caption}"
                               Foreground="{DynamicResource Brush.Text.Tertiary}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Aviso do que NÃO subiu. Aqui o binding é direto (sem RelativeSource) de propósito:
                     HasConflicts/ConflictText/ShowConflictsCommand são da SyncStatusViewModel, que É o
                     DataContext deste Border. Invisível quando não há nada. -->
                <Button x:Name="ConflictIndicator"
                        DockPanel.Dock="Left"
                        Command="{Binding ShowConflictsCommand}"
                        Style="{DynamicResource Button.Ghost}"
                        Padding="0"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        ToolTip="Ver o que não subiu para a nuvem"
                        Visibility="{Binding HasConflicts, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="·"
                                   Style="{DynamicResource Text.Caption}"
                                   Foreground="{DynamicResource Brush.Text.Tertiary}"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ConflictText}"
                                   Style="{DynamicResource Text.Caption}"
                                   Foreground="{DynamicResource Brush.Status.Pending}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- ATENÇÃO ao DataContext: este Border inteiro está com DataContext="{Binding Sync}"
                     (linha 49). Um binding simples "Update.X" aqui resolveria como Sync.Update.X —
                     propriedade que não existe no SyncStatusViewModel — e falharia EM SILÊNCIO (o WPF
                     não lança em binding quebrado, só registra no trace), deixando o indicador
                     invisível para sempre. Por isso o RelativeSource sobe até o UserControl, cujo
                     DataContext é o BrowserViewModel. -->
                <Button x:Name="UpdateIndicator"
                        DockPanel.Dock="Left"
                        Command="{Binding DataContext.Update.ApplyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Style="{DynamicResource Button.Ghost}"
                        Padding="0"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        ToolTip="{Binding DataContext.Update.HintText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Visibility="{Binding DataContext.Update.HasUpdate, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}">
                    <!-- Pílula com fundo de acento, e não texto solto: na v1.4.2 o aviso era uma
                         legenda discreta do mesmo tamanho do resto da barra, e o operador simplesmente
                         não o viu — um aviso que não é notado falhou na única função que tem. Aqui ele
                         continua NÃO roubando foco (é só um botão na barra), mas passa a saltar aos
                         olhos. Tipografia por token; nenhum tamanho literal (lição da v1.2.24). -->
                    <Border Background="{DynamicResource Brush.Accent.Muted}"
                            BorderBrush="{DynamicResource Brush.Accent.Base}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="8,2">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="⬆"
                                       Style="{DynamicResource Text.Caption}"
                                       Foreground="{DynamicResource Brush.Accent.Base}"
                                       FontWeight="Bold"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DataContext.Update.UpdateText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       Style="{DynamicResource Text.Caption}"
                                       Foreground="{DynamicResource Brush.Accent.Base}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Button>

                <!-- "Sincronizar agora": push+pull. Desabilita sozinho quando não há nuvem. -->
                <Button DockPanel.Dock="Right"
                        Command="{Binding SyncNowCommand}"
                        ToolTip="Sincronizar agora"
                        Cursor="Hand"
                        Padding="6,2"
                        BorderThickness="0"
                        Background="Transparent"
                        Foreground="{DynamicResource Brush.Text.Secondary}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Chrome"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{DynamicResource Radius.Control}"
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{DynamicResource Icon.Sync}"
                                               FontFamily="{DynamicResource Font.Family.Icons}"
                                               FontSize="14"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Sincronizar agora"
                                               Margin="6,0,0,0"
                                               VerticalAlignment="Center"
                                               Style="{DynamicResource Text.Caption}"
                                               Foreground="{TemplateBinding Foreground}"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Brush.Bg.Hover}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                    <Setter Property="Cursor" Value="Arrow"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Retorno do "Sincronizar agora". Declarado DEPOIS do botão de propósito: num
                     DockPanel os filhos com Dock="Right" empilham da direita pra esquerda na ordem de
                     declaração, então o carimbo fica colado à ESQUERDA do botão — o retorno aparece
                     ao lado da coisa que o operador acabou de clicar.

                     POR QUE existe: o clique sempre rodou o ciclo, mas o resultado era descartado.
                     Com o indicador já em "Sincronizado", clicar não mudava NADA na tela — o operador
                     não tinha como saber se o botão funcionava. O carimbo leva a HORA (com segundos),
                     então muda a cada clique mesmo quando o estado final é igual ao inicial.

                     Não é modal, e nem podia ser: um diálogo roubaria o teclado de quem está digitando
                     num equipamento em produção (mesmo racional do aviso de atualização acima).

                     Bindings diretos (sem RelativeSource) porque este Border está com
                     DataContext="{Binding Sync}" (linha 49) e as três propriedades são da
                     SyncStatusViewModel. Invisível até o primeiro clique. -->
                <StackPanel x:Name="SyncOutcomeIndicator"
                            DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"
                            ToolTip="{Binding SyncOutcomeDetail}"
                            Visibility="{Binding HasSyncOutcome, Converter={StaticResource BoolToVis}}">
                    <TextBlock x:Name="SyncOutcomeLabel"
                               Text="{Binding SyncOutcomeText}"
                               Style="{StaticResource Sync.Outcome}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Rail à esquerda: seções (Hosts/Keychain/Logs) + avatar/menu da conta no rodapé -->
        <Border DockPanel.Dock="Left"
                Width="70"
                Background="{DynamicResource Brush.Bg.Surface}"
                BorderBrush="{DynamicResource Brush.Border.Subtle}"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Avatar da conta: abre o menu (Configurações / Verificar atualizações / Sobre) -->
                <Button DockPanel.Dock="Bottom"
                        Margin="8,4,8,12"
                        Padding="0"
                        Width="36" Height="36"
                        HorizontalAlignment="Center"
                        Background="{DynamicResource Brush.Accent.Muted}"
                        BorderBrush="{DynamicResource Brush.Border.Default}"
                        BorderThickness="1"
                        ToolTip="Conta"
                        Click="AvatarButton_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="18"/>
                        </Style>
                    </Button.Resources>
                    <Grid>
                        <TextBlock Text="{DynamicResource Icon.Person}"
                                   FontFamily="{DynamicResource Font.Family.Icons}"
                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <Ellipse Width="9" Height="9"
                                 HorizontalAlignment="Right" VerticalAlignment="Top"
                                 Margin="0,-2,-2,0"
                                 Fill="{DynamicResource Brush.Accent.Base}"
                                 Stroke="{DynamicResource Brush.Bg.Surface}" StrokeThickness="1.5"
                                 ToolTip="Há novidades"
                                 Visibility="{Binding HasUnreadChangelog, Converter={StaticResource BoolToVis}}"/>
                    </Grid>
                    <Button.ContextMenu>
                        <ContextMenu x:Name="AccountMenu" Placement="Top">
                            <MenuItem Header="Configurações" Command="{Binding OpenSettingsCommand}">
                                <MenuItem.Icon>
                                    <TextBlock Text="{DynamicResource Icon.Settings}" FontFamily="{DynamicResource Font.Family.Icons}"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Verificar atualizações" Command="{Binding CheckUpdatesCommand}">
                                <MenuItem.Icon>
                                    <TextBlock Text="{DynamicResource Icon.Sync}" FontFamily="{DynamicResource Font.Family.Icons}"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="Sobre" Command="{Binding AboutCommand}">
                                <MenuItem.Icon>
                                    <TextBlock Text="{DynamicResource Icon.Info}" FontFamily="{DynamicResource Font.Family.Icons}"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <!-- Seções de navegação -->
                <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">
                    <RadioButton Style="{DynamicResource Rail.Item}"
                                 IsChecked="{Binding IsHosts, Mode=OneWay}"
                                 Command="{Binding ShowHostsCommand}"
                                 ToolTip="Hosts">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Icon.Network}"
                                       FontFamily="{DynamicResource Font.Family.Icons}"
                                       FontSize="18"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Hosts"
                                       Style="{DynamicResource Text.Micro}"
                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                       HorizontalAlignment="Center"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{DynamicResource Rail.Item}"
                                 IsChecked="{Binding IsKeychain, Mode=OneWay}"
                                 Command="{Binding ShowKeychainCommand}"
                                 ToolTip="Chaveiro">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Icon.Keychain}"
                                       FontFamily="{DynamicResource Font.Family.Icons}"
                                       FontSize="18"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Chaveiro"
                                       Style="{DynamicResource Text.Micro}"
                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                       HorizontalAlignment="Center"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{DynamicResource Rail.Item}"
                                 IsChecked="{Binding IsLogs, Mode=OneWay}"
                                 Command="{Binding ShowLogsCommand}"
                                 ToolTip="Logs">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Icon.Logs}"
                                       FontFamily="{DynamicResource Font.Family.Icons}"
                                       FontSize="18"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Logs"
                                       Style="{DynamicResource Text.Micro}"
                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                       HorizontalAlignment="Center"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- Conteúdo: alterna Hosts/Keychain/Logs conforme a seção ativa -->
        <Grid>
            <views:HostsView DataContext="{Binding Hosts}"
                              Visibility="{Binding DataContext.IsHosts, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"/>
            <views:KeychainView DataContext="{Binding Keychain}"
                                 Visibility="{Binding DataContext.IsKeychain, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"/>
            <views:LogsView DataContext="{Binding Logs}"
                             Visibility="{Binding DataContext.IsLogs, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"/>
        </Grid>

    </DockPanel>
</UserControl>
