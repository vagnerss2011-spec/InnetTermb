<Window x:Class="RemoteOps.Desktop.Views.AccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RemoteOps — Conta" Height="Auto" Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{DynamicResource Brush.Bg.App}"
        Foreground="{DynamicResource Brush.Text.Primary}"
        FontFamily="{DynamicResource Font.Family.Base}"
        FontSize="{DynamicResource Font.Size.Body}">
    <!--
        Entrar / Criar conta (Fase 1 E2EE, spec §8). TextBox/PasswordBox/CheckBox/Button NÃO levam
        Background/Foreground/BorderBrush aqui de propósito: o tema define estilo IMPLÍCITO por
        TargetType (Themes/Controls/*.xaml) e sobrescrever localmente é o que produz o controle
        "claro do Aero2" no meio da janela escura (regressão v1.2.24).
    -->
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <StackPanel Margin="20">
        <TextBlock Text="{Binding Title}" Style="{DynamicResource Text.TitleLg}" Margin="0,0,0,4"/>

        <!-- ── Entrar / Criar conta ── -->
        <StackPanel Visibility="{Binding IsFormMode, Converter={StaticResource BoolToVis}}">
            <TextBlock Style="{DynamicResource Text.Caption}" TextWrapping="Wrap" Margin="0,0,0,16"
                       Text="Seus dados e as senhas dos equipamentos são cifrados neste computador. O servidor nunca recebe a sua senha."/>

            <TextBlock Text="E-mail" Style="{DynamicResource Text.Caption}" Margin="0,0,0,2"/>
            <TextBox x:Name="EmailField" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding IsIdle}" Margin="0,0,0,10"/>

            <TextBlock Text="Senha" Style="{DynamicResource Text.Caption}" Margin="0,0,0,2"/>
            <PasswordBox x:Name="PasswordField" Height="28" IsEnabled="{Binding IsIdle}" Margin="0,0,0,10"/>

            <!-- ── Desafio de 2FA (login): aparece quando o backend responde mfa_required ── -->
            <StackPanel Visibility="{Binding IsMfaChallenge, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Código de verificação (2FA)" Style="{DynamicResource Text.Caption}" Margin="0,0,0,2"/>
                <TextBox x:Name="TotpField" MaxLength="6"
                         Text="{Binding TotpCode, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsIdle}" Margin="0,0,0,6"/>
                <TextBlock Style="{DynamicResource Text.Caption}" TextWrapping="Wrap" Margin="0,0,0,10"
                           Text="Abra seu aplicativo autenticador (Google Authenticator, Authy…) e digite o código de 6 dígitos."/>
            </StackPanel>

            <StackPanel Visibility="{Binding IsRegisterMode, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Confirmar senha" Style="{DynamicResource Text.Caption}" Margin="0,0,0,2"/>
                <PasswordBox x:Name="ConfirmPasswordField" Height="28" IsEnabled="{Binding IsIdle}" Margin="0,0,0,10"/>

                <TextBlock Text="Nome do workspace" Style="{DynamicResource Text.Caption}" Margin="0,0,0,2"/>
                <TextBox x:Name="WorkspaceField" Text="{Binding WorkspaceName, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsIdle}" Margin="0,0,0,10"/>

                <TextBlock Style="{DynamicResource Text.Caption}" TextWrapping="Wrap" Margin="0,0,0,10"
                           Text="A sua senha é a única chave do cofre. Guarde-a bem: o servidor não consegue redefini-la nem abrir os seus dados."/>
            </StackPanel>

            <Border Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                    Background="{DynamicResource Brush.Status.CriticalSurface}"
                    BorderBrush="{DynamicResource Brush.Status.CriticalBase}"
                    BorderThickness="1" CornerRadius="{DynamicResource Radius.Control}"
                    Padding="10,6" Margin="0,0,0,10">
                <TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap"
                           Foreground="{DynamicResource Brush.Status.Error}"/>
            </Border>

            <TextBlock Text="{Binding StatusMessage}" Style="{DynamicResource Text.Caption}"
                       TextWrapping="Wrap" Margin="0,0,0,10"
                       Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}"/>

            <Button x:Name="SubmitButton" Content="{Binding SubmitButtonText}"
                    Style="{DynamicResource Button.Primary}" IsDefault="True"
                    IsEnabled="{Binding IsIdle}" Click="Submit_Click"
                    Padding="10,6" Margin="0,4,0,10"/>

            <Button Content="Não tenho conta — criar uma" Style="{DynamicResource Button.Ghost}"
                    Command="{Binding SwitchToRegisterCommand}" IsEnabled="{Binding IsIdle}"
                    HorizontalAlignment="Center" Padding="8,4"
                    Visibility="{Binding IsLoginMode, Converter={StaticResource BoolToVis}}"/>

            <Button Content="Esqueci a senha" Style="{DynamicResource Button.Ghost}"
                    Click="ForgotPassword_Click" IsEnabled="{Binding IsIdle}"
                    HorizontalAlignment="Center" Padding="8,4"
                    Visibility="{Binding IsLoginMode, Converter={StaticResource BoolToVis}}"/>
            <Button Content="Já tenho conta — entrar" Style="{DynamicResource Button.Ghost}"
                    Command="{Binding SwitchToLoginCommand}" IsEnabled="{Binding IsIdle}"
                    HorizontalAlignment="Center" Padding="8,4"
                    Visibility="{Binding IsRegisterMode, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>

        <!-- ── Pós-registro: a chave de recuperação, exibida UMA vez ── -->
        <StackPanel Visibility="{Binding IsRecoveryMode, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource Brush.Status.CriticalSurface}"
                    BorderBrush="{DynamicResource Brush.Status.CriticalBase}"
                    BorderThickness="1" CornerRadius="{DynamicResource Radius.Control}"
                    Padding="10,8" Margin="0,12,0,12">
                <TextBlock TextWrapping="Wrap"
                           Text="Esta chave aparece UMA ÚNICA VEZ e não pode ser exibida de novo. Ela é a única forma de reabrir o cofre se você esquecer a senha. Sem a senha E sem esta chave, os seus dados ficam irrecuperáveis — nem o servidor consegue abri-los."/>
            </Border>

            <Border Background="{DynamicResource Brush.Bg.Surface}"
                    BorderBrush="{DynamicResource Brush.Border.Default}"
                    BorderThickness="1" CornerRadius="{DynamicResource Radius.Surface}"
                    Padding="12" Margin="0,0,0,10">
                <TextBlock x:Name="RecoveryKeyText" Text="{Binding RecoveryKey}"
                           Style="{DynamicResource Text.Mono}" TextWrapping="Wrap" TextAlignment="Center"/>
            </Border>

            <Button Content="Copiar chave" Command="{Binding CopyRecoveryCommand}"
                    HorizontalAlignment="Center" Padding="10,4" Margin="0,0,0,6"/>

            <TextBlock Text="{Binding StatusMessage}" Style="{DynamicResource Text.Caption}"
                       TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,6"
                       Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}"/>

            <CheckBox IsChecked="{Binding RecoveryAcknowledged}" Margin="0,6,0,12">
                <TextBlock Text="Guardei a chave de recuperação em local seguro." TextWrapping="Wrap"/>
            </CheckBox>

            <Button Content="Concluir" Style="{DynamicResource Button.Primary}"
                    Command="{Binding FinishCommand}" IsDefault="True" Padding="10,6"/>
        </StackPanel>
    </StackPanel>
</Window>
