<UserControl x:Class="RemoteOps.Desktop.Views.TabsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RemoteOps.Desktop.ViewModels"
             xmlns:terminal="clr-namespace:RemoteOps.Desktop.Terminal"
             xmlns:rdp="clr-namespace:RemoteOps.Desktop.Rdp"
             xmlns:ndesk="clr-namespace:RemoteOps.Desktop.NDesk">

    <UserControl.Resources>
        <!-- Implicit DataTemplate: WPF applies this automatically for TerminalTabViewModel -->
        <DataTemplate DataType="{x:Type terminal:TerminalTabViewModel}">
            <terminal:TerminalTabView />
        </DataTemplate>
        <!-- Implicit DataTemplate: WPF applies this automatically for RdpTabViewModel -->
        <DataTemplate DataType="{x:Type rdp:RdpTabViewModel}">
            <rdp:RdpTabView />
        </DataTemplate>
        <!-- Implicit DataTemplate: WPF applies this automatically for NDeskTabViewModel -->
        <DataTemplate DataType="{x:Type ndesk:NDeskTabViewModel}">
            <ndesk:NDeskTabView />
        </DataTemplate>
        <!-- Fallback for future non-terminal/non-rdp tab types -->
        <DataTemplate DataType="{x:Type vm:SessionTabViewModel}">
            <TextBlock Text="{Binding Title}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource Brush.Text.Secondary}"
                       FontSize="13"
                       FontStyle="Italic"/>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <!-- Placeholder sem sessões -->
        <TextBlock Text="Nenhuma sessão ativa. Selecione um host e clique em SSH, Telnet ou RDP."
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Foreground="{DynamicResource Brush.Text.Secondary}"
                   TextWrapping="Wrap"
                   Margin="16">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasTabs}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Abas de sessão -->
        <TabControl ItemsSource="{Binding Tabs}"
                    SelectedItem="{Binding ActiveTab, Mode=TwoWay}">
            <TabControl.Style>
                <!-- BasedOn obrigatório: TabControl.Style local aqui substituiria por
                     completo o Style implícito escuro de Themes/Controls/TabControl.xaml. -->
                <Style TargetType="TabControl" BasedOn="{StaticResource {x:Type TabControl}}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasTabs}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Style>
            <TabControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:SessionTabViewModel}">
                    <StackPanel Orientation="Horizontal">
                        <!-- Selo de protocolo: ícone por ProtocolLabel (SSH/TELNET/RDP/NDESK),
                             lido do mesmo dado que já formatava o texto antigo — nenhum
                             binding novo, só um Style com DataTrigger sobre ele. -->
                        <TextBlock Margin="0,0,4,0" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource Icon.Style}">
                                    <Setter Property="FontSize" Value="10"/>
                                    <Setter Property="Text" Value="{DynamicResource Icon.Connect}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ProtocolLabel}" Value="RDP">
                                            <Setter Property="Text" Value="{DynamicResource Icon.RemoteDesktop}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ProtocolLabel}" Value="NDESK">
                                            <Setter Property="Text" Value="{DynamicResource Icon.Shield}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                        <Button Command="{Binding DataContext.CloseTabCommand,
                                          RelativeSource={RelativeSource AncestorType=TabControl}}"
                                CommandParameter="{Binding}"
                                Style="{DynamicResource Button.Ghost}"
                                Margin="6,0,0,0"
                                Padding="2,0"
                                VerticalAlignment="Center">
                            <!-- Abas fixadas (IsPinned, ex. NDesk) não podem ser fechadas
                                 (CloseTabCommand.CanExecute já bloqueia) — trocamos o glifo
                                 para um pino em vez do X, deixando o estado existente visível
                                 em vez de só desabilitar silenciosamente o botão. -->
                            <TextBlock FontFamily="{DynamicResource Font.Family.Icons}" FontSize="9">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{DynamicResource Icon.Close}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                <Setter Property="Text" Value="{DynamicResource Icon.Pin}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>
            <!-- ContentTemplate intentionally omitted: implicit DataTemplates above are used -->
        </TabControl>
    </Grid>
</UserControl>
