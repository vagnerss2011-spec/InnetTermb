<UserControl x:Class="RemoteOps.Desktop.Terminal.NativeTerminalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vt="clr-namespace:RemoteOps.Desktop.Terminal.Vt"
             Background="#1E1E1E"
             Focusable="False"
             IsTabStop="False">
    <!-- Terminal NATIVO (WPF puro), sem WebView2: renderiza claro e é imune ao MPO. -->
    <Grid>
        <vt:TerminalScreenControl x:Name="Surface"/>
        <!-- KeyboardSink: TextBox TRANSPARENTE cobrindo o terminal inteiro. Clicar nele dá foco de
             teclado AUTOMATICAMENTE (comportamento nativo do TextBox — igual ao campo de busca, que
             comprovadamente recebe teclado; um FrameworkElement cru NÃO pegava foco). O teclado é
             interceptado nos Preview* e mandado pro host (nada é digitado no TextBox); o mouse é
             repassado ao Surface pra seleção/cópia. Transparente (brushes) mas hit-testável. -->
        <TextBox x:Name="KeyboardSink"
                 Background="Transparent" Foreground="Transparent"
                 CaretBrush="Transparent" SelectionBrush="Transparent"
                 BorderThickness="0" IsTabStop="False"
                 ContextMenu="{x:Null}"
                 AcceptsReturn="True" AcceptsTab="True"
                 VerticalContentAlignment="Top"/>
    </Grid>
</UserControl>
