<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        RadioButton e CheckBox temáticos (tema escuro).

        Antes NÃO existia estilo próprio: os poucos RadioButton/CheckBox do app caíam
        no template padrão do WPF (Aero2, claro), cujo indicador é desenhado a partir
        de BITMAPS de tema — não reescalam com nitidez em monitores de DPI diferente.
        Depois do Per-Monitor-V2 (v1.2.23) isso ficou visível: indicadores de tamanhos
        diferentes, tortos e destoando dos controles temáticos ao redor ("desconexo").

        Estes estilos IMPLÍCITOS (sem x:Key) valem para todo RadioButton/CheckBox e
        entregam: indicador VETORIAL de 16px (nítido em qualquer DPI, SnapsToDevicePixels),
        fonte base do tema, e alinhamento central do indicador com o texto. Estilos com
        x:Key (ex.: Rail.Item no BrowserView) continuam prevalecendo — o rail de navegação
        não é afetado. Ver docs/06-desktop-ui-ux.md §Sistema de design.
    -->

    <!-- RadioButton: círculo (borda) + ponto de acento quando marcado. -->
    <Style TargetType="RadioButton">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="FontFamily" Value="{DynamicResource Font.Family.Base}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Body}"/>
        <Setter Property="Background" Value="{DynamicResource Brush.Bg.Canvas}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <!-- retângulo pontilhado padrão de foco fica feio sobre o indicador vetorial;
             o foco de teclado é sinalizado pela borda de acento (trigger abaixo). -->
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" Width="16" Height="16" VerticalAlignment="Center">
                            <Ellipse x:Name="Outer"
                                     Stroke="{TemplateBinding BorderBrush}" StrokeThickness="1.5"
                                     Fill="{TemplateBinding Background}"
                                     SnapsToDevicePixels="True"/>
                            <Ellipse x:Name="Dot" Width="7" Height="7"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                     Fill="{DynamicResource Brush.Accent.Base}"
                                     Visibility="Collapsed"/>
                        </Grid>
                        <ContentPresenter Grid.Column="1" Margin="8,0,0,0"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Outer" Property="Stroke" Value="{DynamicResource Brush.Accent.Base}"/>
                            <Setter TargetName="Dot" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Outer" Property="Stroke" Value="{DynamicResource Brush.Accent.Hover}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Outer" Property="Stroke" Value="{DynamicResource Brush.Accent.Base}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- CheckBox: caixa arredondada + "check" vetorial preenchido de acento quando marcado. -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="FontFamily" Value="{DynamicResource Font.Family.Base}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Body}"/>
        <Setter Property="Background" Value="{DynamicResource Brush.Bg.Canvas}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0" Width="16" Height="16" VerticalAlignment="Center">
                            <Border x:Name="Box"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1.5"
                                    CornerRadius="{DynamicResource Radius.Control}"
                                    SnapsToDevicePixels="True"/>
                            <!-- traço do estado indeterminado -->
                            <Rectangle x:Name="Dash" Width="8" Height="2" RadiusX="1" RadiusY="1"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Fill="{DynamicResource Brush.Text.OnAccent}"
                                       Visibility="Collapsed"/>
                            <Path x:Name="Check"
                                  Data="M 4,8.5 L 7,11.5 L 12.5,5"
                                  Stroke="{DynamicResource Brush.Text.OnAccent}"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Stretch="None"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Visibility="Collapsed"/>
                        </Grid>
                        <ContentPresenter Grid.Column="1" Margin="8,0,0,0"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource Brush.Accent.Base}"/>
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Brush.Accent.Base}"/>
                            <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="{x:Null}">
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource Brush.Accent.Base}"/>
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Brush.Accent.Base}"/>
                            <Setter TargetName="Dash" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Brush.Accent.Hover}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Brush.Accent.Base}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
