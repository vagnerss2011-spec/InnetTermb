<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Separator (Inspector) -->
    <Style TargetType="Separator">
        <Setter Property="Background" Value="{DynamicResource Brush.Border.Subtle}"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Height="1" Background="{TemplateBinding Background}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ToolTip: já usado (via atributo ToolTip="texto") pela maioria dos TextBox/Button
         das Views atuais; o WPF cria um ToolTip real por trás desse atalho, então este
         Style implícito é suficiente — não requer tocar nenhuma View para funcionar. -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{DynamicResource Brush.Bg.SurfaceRaised}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Strong}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="FontFamily" Value="{DynamicResource Font.Family.Base}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Caption}"/>
        <Setter Property="HasDropShadow" Value="False"/>
    </Style>

</ResourceDictionary>
