<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        RemoteOps — paleta "Slate Signal" (tema escuro base).

        Fundos: rampa slate-azulada (não neutra, não preto puro) — identidade de console de
        operação, distinta do cinza neutro genérico.
        Accent: ciano-sinal — remete a conectividade/rede, deliberadamente distinto do
        azul/roxo padrão de produtos SaaS.
        Status: mapeia estados que já existem nos ViewModels (sync, sessão NDesk, erros de
        validação) — a cor carrega significado, não é decoração. Ver
        docs/06-desktop-ui-ux.md §Sistema de design.

        Convenção de consumo: Views usam DynamicResource (não StaticResource) para os brushes
        abaixo, para manter aberta a porta de um tema claro futuro (docs/06 §Acessibilidade,
        "Tema claro/escuro") sem precisar tocar bindings depois.
    -->

    <!-- ===== Cores primitivas ===== -->

    <Color x:Key="Color.Bg950">#FF12151A</Color>
    <!-- Bg.App: janela/base, o mais escuro -->
    <Color x:Key="Color.Bg900">#FF181C22</Color>
    <!-- Bg.Canvas: superfícies de sessão (terminal/rdp/ndesk) -->
    <Color x:Key="Color.Bg800">#FF1E232B</Color>
    <!-- Bg.Surface: sidebar, lista de hosts, inspector -->
    <Color x:Key="Color.Bg700">#FF262C36</Color>
    <!-- Bg.SurfaceRaised: barra superior, cabeçalhos, toolbars -->
    <Color x:Key="Color.Bg600">#FF2E3542</Color>
    <!-- Bg.Hover -->
    <Color x:Key="Color.Bg500">#FF38414F</Color>
    <!-- Bg.Selected (neutro, sem foco) -->

    <Color x:Key="Color.BorderSubtle">#FF2B313C</Color>
    <Color x:Key="Color.BorderDefault">#FF3A4250</Color>
    <Color x:Key="Color.BorderStrong">#FF4A5464</Color>

    <Color x:Key="Color.TextPrimary">#FFEAEDF2</Color>
    <Color x:Key="Color.TextSecondary">#FF9FA9B8</Color>
    <Color x:Key="Color.TextTertiary">#FF647085</Color>
    <Color x:Key="Color.TextOnAccent">#FF0B1620</Color>

    <Color x:Key="Color.AccentBase">#FF33B7D1</Color>
    <Color x:Key="Color.AccentHover">#FF4FC8E0</Color>
    <Color x:Key="Color.AccentPressed">#FF279AB0</Color>
    <Color x:Key="Color.AccentMuted">#FF1F3A42</Color>
    <!-- fundo dessaturado p/ seleção (linha de host, item de árvore) -->

    <!-- Semânticas de status — reusadas em sync (topo), sessão NDesk, validação de host -->
    <Color x:Key="Color.StatusOnline">#FF3ED598</Color>
    <Color x:Key="Color.StatusPending">#FFE8B23A</Color>
    <Color x:Key="Color.StatusError">#FFE5566D</Color>
    <Color x:Key="Color.StatusIdle">#FF6B7686</Color>
    <Color x:Key="Color.StatusCriticalSurface">#FF4A2430</Color>
    <!-- fundo de banner de sessão ativa/perigo -->
    <Color x:Key="Color.StatusCriticalBase">#FFC64258</Color>
    <!-- ação destrutiva (Encerrar) -->

    <!-- ===== Brushes semânticos ===== -->

    <SolidColorBrush x:Key="Brush.Bg.App" Color="{StaticResource Color.Bg950}"/>
    <SolidColorBrush x:Key="Brush.Bg.Canvas" Color="{StaticResource Color.Bg900}"/>
    <SolidColorBrush x:Key="Brush.Bg.Surface" Color="{StaticResource Color.Bg800}"/>
    <SolidColorBrush x:Key="Brush.Bg.SurfaceRaised" Color="{StaticResource Color.Bg700}"/>
    <SolidColorBrush x:Key="Brush.Bg.Hover" Color="{StaticResource Color.Bg600}"/>
    <SolidColorBrush x:Key="Brush.Bg.Selected" Color="{StaticResource Color.Bg500}"/>

    <SolidColorBrush x:Key="Brush.Border.Subtle" Color="{StaticResource Color.BorderSubtle}"/>
    <SolidColorBrush x:Key="Brush.Border.Default" Color="{StaticResource Color.BorderDefault}"/>
    <SolidColorBrush x:Key="Brush.Border.Strong" Color="{StaticResource Color.BorderStrong}"/>

    <SolidColorBrush x:Key="Brush.Text.Primary" Color="{StaticResource Color.TextPrimary}"/>
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{StaticResource Color.TextSecondary}"/>
    <SolidColorBrush x:Key="Brush.Text.Tertiary" Color="{StaticResource Color.TextTertiary}"/>
    <SolidColorBrush x:Key="Brush.Text.OnAccent" Color="{StaticResource Color.TextOnAccent}"/>

    <SolidColorBrush x:Key="Brush.Accent.Base" Color="{StaticResource Color.AccentBase}"/>
    <SolidColorBrush x:Key="Brush.Accent.Hover" Color="{StaticResource Color.AccentHover}"/>
    <SolidColorBrush x:Key="Brush.Accent.Pressed" Color="{StaticResource Color.AccentPressed}"/>
    <SolidColorBrush x:Key="Brush.Accent.Muted" Color="{StaticResource Color.AccentMuted}"/>

    <SolidColorBrush x:Key="Brush.Status.Online" Color="{StaticResource Color.StatusOnline}"/>
    <SolidColorBrush x:Key="Brush.Status.Pending" Color="{StaticResource Color.StatusPending}"/>
    <SolidColorBrush x:Key="Brush.Status.Error" Color="{StaticResource Color.StatusError}"/>
    <SolidColorBrush x:Key="Brush.Status.Idle" Color="{StaticResource Color.StatusIdle}"/>
    <SolidColorBrush x:Key="Brush.Status.CriticalSurface" Color="{StaticResource Color.StatusCriticalSurface}"/>
    <SolidColorBrush x:Key="Brush.Status.CriticalBase" Color="{StaticResource Color.StatusCriticalBase}"/>

    <!--
        Rede de segurança: os templates padrão (Aero2) de vários controles WPF (partes de
        ComboBoxItem, TreeViewItem, ScrollBar, etc.) buscam cor via DynamicResource nas chaves
        de SystemColors abaixo em vez de cor fixa — é o hook de tema oficial do próprio WPF.
        Sobrescrever aqui dá cobertura extra em qualquer parte de controle que não seja
        explicitamente retemplada em Themes/Controls/, sem risco: é só troca de brush.
    -->
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="{StaticResource Color.Bg800}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="{StaticResource Color.TextPrimary}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="{StaticResource Color.Bg700}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="{StaticResource Color.TextPrimary}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="{StaticResource Color.Bg600}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}" Color="{StaticResource Color.BorderDefault}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{StaticResource Color.AccentMuted}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="{StaticResource Color.TextPrimary}"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="{StaticResource Color.TextTertiary}"/>

</ResourceDictionary>
