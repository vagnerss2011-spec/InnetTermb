<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--
        Tipografia.

        Font.Family.Base: "Segoe UI Variable Text" é a fonte moderna do Windows 11; a lista
        com vírgula é fallback nativo do WPF — se ausente (Windows 10 sem o pacote opcional),
        cai para "Segoe UI", garantida em qualquer instalação padrão do Windows 10/11.
        Font.Family.Mono: Consolas — fonte do sistema desde o Windows Vista, usada para dados
        técnicos (IP/FQDN, tags, tickets) por convenção de console de operação.
    -->
    <FontFamily x:Key="Font.Family.Base">Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="Font.Family.Mono">Consolas</FontFamily>

    <!-- Escala de tamanho -->
    <sys:Double x:Key="Font.Size.TitleLg">16</sys:Double>
    <sys:Double x:Key="Font.Size.Title">14</sys:Double>
    <sys:Double x:Key="Font.Size.Body">13</sys:Double>
    <sys:Double x:Key="Font.Size.Caption">11</sys:Double>
    <sys:Double x:Key="Font.Size.Micro">10</sys:Double>

    <!-- Estilos de texto prontos para uso — BasedOn encadeado a partir de Text.Base.
         Consumidos explicitamente (Style="{DynamicResource Text.X}"); não há Style
         implícito global de TextBlock — o app usa herança de Foreground/FontFamily/FontSize
         a partir da raiz (Window/UserControl) para o caso base, e estes estilos nomeados
         para os casos com tratamento tipográfico distinto (título, legenda, dado técnico). -->

    <Style x:Key="Text.Base" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Font.Family.Base}"/>
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Body}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
    </Style>

    <Style x:Key="Text.TitleLg" TargetType="TextBlock" BasedOn="{StaticResource Text.Base}">
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.TitleLg}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="Text.Title" TargetType="TextBlock" BasedOn="{StaticResource Text.Base}">
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Title}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="Text.Body" TargetType="TextBlock" BasedOn="{StaticResource Text.Base}"/>

    <Style x:Key="Text.BodyStrong" TargetType="TextBlock" BasedOn="{StaticResource Text.Base}">
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="Text.Secondary" TargetType="TextBlock" BasedOn="{StaticResource Text.Base}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}"/>
    </Style>

    <Style x:Key="Text.Caption" TargetType="TextBlock" BasedOn="{StaticResource Text.Base}">
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Caption}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}"/>
    </Style>

    <Style x:Key="Text.Micro" TargetType="TextBlock" BasedOn="{StaticResource Text.Base}">
        <Setter Property="FontSize" Value="{DynamicResource Font.Size.Micro}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Tertiary}"/>
    </Style>

    <Style x:Key="Text.Mono" TargetType="TextBlock" BasedOn="{StaticResource Text.Base}">
        <Setter Property="FontFamily" Value="{DynamicResource Font.Family.Mono}"/>
    </Style>

</ResourceDictionary>
